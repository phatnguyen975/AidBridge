<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/admin_screen_background"
    android:paddingStart="@dimen/admin_screen_padding"
    android:paddingTop="@dimen/admin_screen_padding"
    android:paddingEnd="@dimen/admin_screen_padding"
    android:paddingBottom="@dimen/admin_screen_padding">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_admin_add_supply_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/button_admin_add_supply_back"
            android:layout_width="@dimen/admin_hub_mgmt_header_back_size"
            android:layout_height="@dimen/admin_hub_mgmt_header_back_size"
            android:background="@android:color/transparent"
            android:contentDescription="@string/admin_add_supply_type_back"
            android:padding="@dimen/admin_stat_value_spacing"
            android:src="@drawable/ic_admin_back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:tint="@color/admin_text_primary" />

        <TextView
            android:id="@+id/text_admin_add_supply_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_add_supply_type_title"
            android:textColor="@color/admin_text_primary"
            android:textSize="@dimen/admin_screen_title_text_size"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_save_supply_type"
        android:layout_width="0dp"
        android:layout_height="@dimen/admin_add_supply_type_save_button_height"
        android:text="@string/admin_add_supply_type_save_button"
        android:textAllCaps="false"
        android:textColor="@color/admin_action_button_text"
        android:textSize="@dimen/admin_action_button_text_size"
        app:backgroundTint="@color/admin_action_button_primary_bg"
        app:cornerRadius="@dimen/admin_action_button_radius"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_admin_add_supply_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/admin_section_spacing"
        android:layout_marginBottom="@dimen/admin_section_spacing"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/layout_admin_add_supply_header"
        app:layout_constraintBottom_toTopOf="@id/button_save_supply_type"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/admin_add_supply_type_category_label"
                android:textColor="@color/admin_text_primary"
                android:textSize="@dimen/admin_hub_item_sub_text_size"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinner_supply_category"
                android:layout_width="match_parent"
                android:layout_height="@dimen/admin_add_supply_type_spinner_height"
                android:layout_marginTop="@dimen/admin_add_supply_type_field_spacing"
                android:background="@drawable/bg_admin_inventory_row"
                android:paddingStart="@dimen/admin_add_supply_type_spinner_padding_horizontal"
                android:paddingEnd="@dimen/admin_add_supply_type_spinner_padding_horizontal"
                android:popupBackground="@color/admin_detail_card_bg"
                android:spinnerMode="dropdown" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/admin_add_supply_type_section_spacing"
                android:text="@string/admin_add_supply_type_unit_label"
                android:textColor="@color/admin_text_primary"
                android:textSize="@dimen/admin_hub_item_sub_text_size"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/admin_add_supply_type_field_spacing"
                app:boxBackgroundColor="@color/admin_search_bg"
                app:boxBackgroundMode="filled"
                app:boxStrokeColor="@color/admin_search_border"
                app:hintTextColor="@color/admin_search_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_text_supply_unit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:focusable="false"
                    android:textColor="@color/admin_text_primary"
                    android:textColorHint="@color/admin_search_hint" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/admin_add_supply_type_section_spacing"
                android:text="@string/admin_add_supply_type_min_level_label"
                android:textColor="@color/admin_text_primary"
                android:textSize="@dimen/admin_hub_item_sub_text_size"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/admin_add_supply_type_field_spacing"
                android:hint="@string/admin_add_supply_type_min_level_hint"
                app:boxBackgroundColor="@color/admin_search_bg"
                app:boxBackgroundMode="filled"
                app:boxStrokeColor="@color/admin_search_border"
                app:hintTextColor="@color/admin_search_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_text_supply_min_level"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/admin_text_primary"
                    android:textColorHint="@color/admin_search_hint" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/admin_add_supply_type_section_spacing"
                android:text="@string/admin_add_supply_type_note_label"
                android:textColor="@color/admin_text_primary"
                android:textSize="@dimen/admin_hub_item_sub_text_size"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/admin_add_supply_type_field_spacing"
                android:hint="@string/admin_add_supply_type_note_hint"
                app:boxBackgroundColor="@color/admin_search_bg"
                app:boxBackgroundMode="filled"
                app:boxStrokeColor="@color/admin_search_border"
                app:hintTextColor="@color/admin_search_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_text_supply_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:minLines="@integer/admin_add_supply_type_note_min_lines"
                    android:textColor="@color/admin_text_primary"
                    android:textColorHint="@color/admin_search_hint" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>