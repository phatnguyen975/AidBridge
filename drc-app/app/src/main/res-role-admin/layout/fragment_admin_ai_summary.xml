<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/admin_screen_background">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_admin_ai_summary"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="@dimen/admin_screen_padding"
        android:paddingTop="@dimen/admin_screen_padding"
        android:paddingEnd="@dimen/admin_screen_padding"
        android:paddingBottom="@dimen/admin_ai_summary_scroll_bottom_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/text_admin_ai_summary_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/admin_ai_summary_title"
                android:textColor="@color/admin_text_primary"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/text_admin_ai_last_updated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/admin_ai_summary_updated_top_margin"
                android:text="@string/admin_ai_summary_updated_placeholder"
                android:textColor="@color/admin_text_secondary"
                android:textSize="@dimen/admin_hub_item_sub_text_size"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/text_admin_ai_summary_title" />

            <TextView
                android:id="@+id/tv_error_message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/admin_hub_item_spacing_small"
                android:gravity="center"
                android:textColor="@color/admin_button_danger_bg"
                android:textSize="@dimen/admin_hub_item_sub_text_size"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/text_admin_ai_last_updated" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_admin_ai_summary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/admin_section_spacing"
                app:cardBackgroundColor="@color/admin_summary_card_bg"
                app:cardCornerRadius="@dimen/admin_hub_detail_card_radius"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_error_message"
                app:strokeColor="@color/admin_summary_card_stroke"
                app:strokeWidth="@dimen/admin_hub_detail_card_stroke">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/admin_ai_summary_card_padding">

                    <ImageView
                        android:id="@+id/image_admin_ai_sparkle"
                        android:layout_width="@dimen/admin_ai_summary_icon_size"
                        android:layout_height="@dimen/admin_ai_summary_icon_size"
                        android:contentDescription="@string/admin_ai_summary_report_icon_desc"
                        android:src="@drawable/ic_admin_sparkle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/text_admin_ai_report_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/admin_stat_text_spacing"
                        android:text="@string/admin_ai_summary_report_title"
                        android:textColor="@color/admin_text_primary"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/image_admin_ai_sparkle"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/image_admin_ai_sparkle"
                        app:layout_constraintTop_toTopOf="@id/image_admin_ai_sparkle" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_admin_ai_goods"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/admin_ai_summary_card_inner_spacing"
                        app:cardBackgroundColor="@color/admin_hub_icon_box_bg"
                        app:cardCornerRadius="@dimen/admin_hub_item_icon_box_radius"
                        app:cardElevation="0dp"
                        app:layout_constraintEnd_toStartOf="@id/card_admin_ai_people"
                        app:layout_constraintHorizontal_chainStyle="spread_inside"
                        app:layout_constraintHorizontal_weight="1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/image_admin_ai_sparkle"
                        app:strokeColor="@color/admin_hub_icon_box_stroke"
                        app:strokeWidth="@dimen/admin_hub_detail_card_stroke">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/admin_ai_summary_mini_card_padding">

                            <TextView
                                android:id="@+id/tv_total_packages"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/admin_ai_summary_goods_placeholder"
                                android:textColor="@color/admin_text_primary"
                                android:textSize="@dimen/admin_ai_summary_mini_card_value_size"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_package_growth"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/admin_stat_value_spacing"
                                android:text="@string/admin_ai_summary_growth_placeholder"
                                android:textColor="@color/admin_ai_summary_growth"
                                android:textSize="@dimen/admin_hub_item_sub_text_size"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_admin_ai_people"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/admin_ai_summary_card_inner_spacing"
                        android:layout_marginTop="@dimen/admin_ai_summary_card_inner_spacing"
                        app:cardBackgroundColor="@color/admin_hub_icon_box_bg"
                        app:cardCornerRadius="@dimen/admin_hub_item_icon_box_radius"
                        app:cardElevation="0dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_weight="1"
                        app:layout_constraintStart_toEndOf="@id/card_admin_ai_goods"
                        app:layout_constraintTop_toBottomOf="@id/image_admin_ai_sparkle"
                        app:strokeColor="@color/admin_hub_icon_box_stroke"
                        app:strokeWidth="@dimen/admin_hub_detail_card_stroke">

                        <TextView
                            android:id="@+id/tv_people_supported"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="@dimen/admin_ai_summary_mini_card_padding"
                            android:text="@string/admin_ai_summary_people_placeholder"
                            android:textColor="@color/admin_text_primary"
                            android:textSize="@dimen/admin_hub_item_sub_text_size"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:id="@+id/layout_alerts_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/admin_ai_summary_alert_top_margin"
                        android:orientation="vertical"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/card_admin_ai_goods" />

                    <TextView
                        android:id="@+id/tv_empty_alerts"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/admin_hub_item_spacing_small"
                        android:text="@string/admin_ai_summary_alert_empty"
                        android:textColor="@color/admin_text_secondary"
                        android:textSize="@dimen/admin_hub_item_sub_text_size"
                        android:visibility="gone"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/layout_alerts_container" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_generate_report"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/admin_hub_detail_button_height"
                        android:layout_marginTop="@dimen/admin_ai_summary_alert_top_margin"
                        android:text="@string/admin_ai_summary_create_report"
                        android:textAllCaps="false"
                        android:textColor="@color/admin_action_button_text"
                        android:textSize="@dimen/text_lg"
                        app:backgroundTint="@color/admin_action_button_primary_bg"
                        app:cornerRadius="@dimen/admin_action_button_radius"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_empty_alerts" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/text_admin_ai_recent_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/admin_section_spacing"
                android:text="@string/admin_ai_summary_recent_title"
                android:textColor="@color/admin_text_primary"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_admin_ai_summary" />

            <TextView
                android:id="@+id/text_admin_ai_view_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/admin_ai_summary_view_all"
                android:textColor="@color/admin_action_button_primary_bg"
                android:textSize="@dimen/text_md"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/text_admin_ai_recent_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/text_admin_ai_recent_title" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_admin_ai_recent_activities"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/admin_hub_item_spacing_medium"
                app:cardBackgroundColor="@color/admin_summary_card_bg"
                app:cardCornerRadius="@dimen/admin_hub_detail_card_radius"
                app:cardElevation="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/text_admin_ai_recent_title"
                app:strokeColor="@color/admin_summary_card_stroke"
                app:strokeWidth="@dimen/admin_hub_detail_card_stroke">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/admin_ai_summary_card_padding">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_recent_activities"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <TextView
                        android:id="@+id/tv_empty_activities"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/admin_hub_item_spacing_small"
                        android:gravity="center"
                        android:text="@string/admin_ai_summary_activities_empty"
                        android:textColor="@color/admin_text_secondary"
                        android:textSize="@dimen/admin_hub_item_sub_text_size"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progress_loading"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:indeterminate="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>