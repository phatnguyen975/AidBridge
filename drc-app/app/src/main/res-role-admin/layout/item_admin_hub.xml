<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/admin_hub_item_spacing_medium"
    app:cardBackgroundColor="@color/admin_hub_card_bg"
    app:cardCornerRadius="@dimen/admin_hub_item_card_radius"
    app:strokeColor="@color/admin_hub_card_stroke"
    app:strokeWidth="@dimen/admin_hub_item_card_stroke">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/admin_hub_item_padding">

        <ImageView
            android:id="@+id/image_hub_thumbnail"
            android:layout_width="@dimen/admin_hub_item_thumbnail_size"
            android:layout_height="@dimen/admin_hub_item_thumbnail_size"
            android:background="@drawable/bg_admin_hub_thumbnail"
            android:clipToOutline="true"
            android:contentDescription="@string/admin_hub_mgmt_hub_thumbnail_desc"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_hub_placeholder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/text_hub_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/admin_hub_item_spacing_medium"
            android:layout_marginEnd="@dimen/admin_hub_item_spacing_small"
            android:textColor="@color/admin_text_primary"
            android:textSize="@dimen/admin_hub_item_title_text_size"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/text_hub_status"
            app:layout_constraintStart_toEndOf="@id/image_hub_thumbnail"
            app:layout_constraintTop_toTopOf="@id/image_hub_thumbnail" />

        <TextView
            android:id="@+id/text_hub_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_admin_badge_active"
            android:paddingStart="@dimen/admin_hub_item_badge_padding_horizontal"
            android:paddingTop="@dimen/admin_hub_item_badge_padding_vertical"
            android:paddingEnd="@dimen/admin_hub_item_badge_padding_horizontal"
            android:paddingBottom="@dimen/admin_hub_item_badge_padding_vertical"
            android:textColor="@color/admin_badge_active_text"
            android:textSize="@dimen/admin_hub_item_badge_text_size"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/text_hub_name" />

        <TextView
            android:id="@+id/text_hub_address"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/admin_hub_item_spacing_small"
            android:textColor="@color/admin_text_secondary"
            android:textSize="@dimen/admin_hub_item_sub_text_size"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/text_hub_name"
            app:layout_constraintTop_toBottomOf="@id/text_hub_name" />

        <TextView
            android:id="@+id/text_hub_operating_hours"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/admin_hub_item_spacing_small"
            android:textColor="@color/admin_text_secondary"
            android:textSize="@dimen/admin_hub_item_sub_text_size"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/text_hub_name"
            app:layout_constraintTop_toBottomOf="@id/text_hub_address" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_hub_details"
            android:layout_width="0dp"
            android:layout_height="@dimen/admin_hub_item_button_height"
            android:layout_marginTop="@dimen/admin_hub_item_spacing_medium"
            android:layout_marginEnd="@dimen/admin_hub_item_spacing_medium"
            android:text="@string/admin_hub_mgmt_btn_details"
            android:textAllCaps="false"
            android:textColor="@color/admin_button_edit_text"
            android:textSize="@dimen/admin_hub_item_sub_text_size"
            app:backgroundTint="@color/admin_button_edit_bg"
            app:cornerRadius="@dimen/admin_hub_item_button_radius"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/button_hub_toggle_status"
            app:layout_constraintStart_toStartOf="@id/text_hub_name"
            app:layout_constraintTop_toBottomOf="@id/text_hub_operating_hours"
            app:strokeColor="@color/admin_button_edit_stroke"
            app:strokeWidth="@dimen/admin_hub_item_card_stroke" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_hub_toggle_status"
            android:layout_width="0dp"
            android:layout_height="@dimen/admin_hub_item_button_height"
            android:layout_marginTop="@dimen/admin_hub_item_spacing_medium"
            android:textAllCaps="false"
            android:textColor="@color/admin_text_primary"
            android:textSize="@dimen/admin_hub_item_sub_text_size"
            app:backgroundTint="@color/admin_button_danger_bg"
            app:cornerRadius="@dimen/admin_hub_item_button_radius"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/button_hub_details"
            app:layout_constraintTop_toBottomOf="@id/text_hub_operating_hours" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>