<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="@dimen/admin_hub_item_spacing_small"
    android:paddingBottom="@dimen/admin_hub_item_spacing_small">

    <ImageView
        android:id="@+id/image_activity_icon"
        android:layout_width="@dimen/admin_ai_summary_warning_icon_size"
        android:layout_height="@dimen/admin_ai_summary_warning_icon_size"
        android:contentDescription="@string/admin_ai_summary_warning_icon_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_activity_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/admin_hub_item_spacing_small"
        android:layout_marginEnd="@dimen/admin_hub_item_spacing_small"
        android:textColor="@color/admin_text_primary"
        android:textSize="@dimen/text_md"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/text_activity_time"
        app:layout_constraintStart_toEndOf="@+id/image_activity_icon"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_activity_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/admin_text_secondary"
        android:textSize="@dimen/admin_hub_item_sub_text_size"
        app:layout_constraintBaseline_toBaselineOf="@id/text_activity_title"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/text_activity_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/admin_text_secondary"
        android:textSize="@dimen/admin_hub_item_sub_text_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/text_activity_title"
        app:layout_constraintTop_toBottomOf="@+id/text_activity_title" />

</androidx.constraintlayout.widget.ConstraintLayout>
