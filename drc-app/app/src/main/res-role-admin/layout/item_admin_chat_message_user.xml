<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="@dimen/admin_hub_item_spacing_small"
    android:paddingBottom="@dimen/admin_hub_item_spacing_small">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_admin_chat_user"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/admin_action_button_primary_bg"
        app:cardCornerRadius="@dimen/admin_chat_message_corner"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintHorizontal_bias="1">

        <TextView
            android:id="@+id/text_admin_chat_user_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="@dimen/admin_chat_message_max_width"
            android:paddingStart="@dimen/admin_hub_item_spacing_medium"
            android:paddingTop="@dimen/admin_hub_item_spacing_small"
            android:paddingEnd="@dimen/admin_hub_item_spacing_medium"
            android:paddingBottom="@dimen/admin_hub_item_spacing_small"
            android:textColor="@color/admin_action_button_text"
            android:textSize="@dimen/admin_hub_item_sub_text_size" />

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
