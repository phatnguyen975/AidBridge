{
  "priority": [
    {
      "if": "true",
      "multiply_by": "1.0"
    },
    {
      "if": "road_class == PRIMARY || road_class == SECONDARY",
      "multiply_by": "0.95"
    },
    {
      "if": "road_class == TRUNK",
      "multiply_by": "0.80"
    },
    {
      "if": "road_class == MOTORWAY",
      "multiply_by": "0.70"
    },
    {
      "if": "road_class == RESIDENTIAL || road_class == SERVICE",
      "multiply_by": "0.25"
    },
    {
      "if": "road_environment == TUNNEL",
      "multiply_by": "0.10"
    },
    {
      "if": "surface == DIRT || surface == UNPAVED || surface == GRAVEL",
      "multiply_by": "0.30"
    },
    {
      "if": "max_speed >= 80",
      "multiply_by": "0.45"
    }
  ],
  "speed": [
    {
      "if": "true",
      "limit_to": "60"
    },
    {
      "if": "road_class == PRIMARY",
      "limit_to": "60"
    },
    {
      "if": "road_class == SECONDARY",
      "limit_to": "50"
    },
    {
      "if": "road_class == RESIDENTIAL || road_class == SERVICE",
      "limit_to": "35"
    },
    {
      "if": "road_environment == TUNNEL",
      "limit_to": "30"
    }
  ]
}
