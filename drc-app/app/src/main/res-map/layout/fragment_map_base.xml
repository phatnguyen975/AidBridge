<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:openDrawer="start">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/base_acceptance_bg">

    <org.osmdroid.views.MapView
        android:id="@+id/osmMapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/base_map_map_overlay" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardNavigationHud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/base_map_hud_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_map_pin"
                android:tint="@color/white"
                tools:ignore="UseAppTint" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvHudPrimaryInstruction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/base_map_instruction_continue"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHudSecondaryInstruction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/base_map_hud_waiting"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>



    <LinearLayout
        android:id="@+id/layoutNavigationActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="16dp"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnArrivedMission"
            style="@style/Widget.Material3.Button.ElevatedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/base_map_cancel_mission"
            android:textColor="@color/safe_green"
            android:textStyle="bold"
            app:backgroundTint="@color/white"
            app:cornerRadius="24dp"
            app:icon="@drawable/ic_check_circle"
            app:iconTint="@color/safe_green" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabFindHubs"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="16dp"
        android:layout_marginTop="150dp"
        android:src="@android:drawable/ic_menu_search"
        app:backgroundTint="#FFFFFF"
        app:fabSize="mini"
        app:tint="#4285F4" />

    <FrameLayout
        android:id="@+id/cardTopOverview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="64dp"
        android:background="@drawable/bg_bottom_sheet_white_rounded"
        android:elevation="7dp"
        android:theme="@style/ThemeOverlay.AidBridge.Light"
        app:behavior_draggable="true"
        app:behavior_fitToContents="true"
        app:behavior_hideable="true"
        app:behavior_peekHeight="0dp"
        app:behavior_skipCollapsed="true"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/transparent"
                android:paddingBottom="24dp">

                <!-- Drag Handle -->
                <View
                    android:layout_width="32dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_map_drag_handle" />

                <!-- Header Info (Luôn hiển thị) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="16dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- Tiêu đề / Map Title -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/tvMapTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/base_map_title"
                                    android:textColor="#888888"
                                    android:textSize="14sp" />

                                <ImageButton
                                    android:id="@+id/btnToggleTopPanel"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_marginStart="8dp"
                                    android:background="@android:color/transparent"
                                    android:contentDescription="@string/base_map_toggle_panel_desc"
                                    android:src="@drawable/ic_arrow_down"
                                    app:tint="#888888" />
                            </LinearLayout>

                            <!-- Điểm đến -->
                            <TextView
                                android:id="@+id/tvPrimaryDestination"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/base_map_end_address_loading_short"
                                android:textColor="#000000"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:maxLines="2"
                                android:ellipsize="end" />
                        </LinearLayout>

                        <!-- Developer & Gọi khẩn cấp -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/bg_circle_icon"
                                android:backgroundTint="#F5F5F5">

                                <ImageView
                                    android:id="@+id/ivDevAvatar"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="6dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:contentDescription="@string/base_map_dev_avatar_desc"
                                    android:src="@drawable/ic_secret_ninja" />

                                <!-- Hidden hint sign (empty text but keeps ID for logic) -->
                                <TextView
                                    android:id="@+id/tvDevHintSign"
                                    android:layout_width="0dp"
                                    android:layout_height="0dp"
                                    android:visibility="gone" />
                            </FrameLayout>

                            <ImageButton
                                android:id="@+id/btnCallVictim"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_circle_icon"
                                android:contentDescription="@string/base_map_call_content_desc"
                                android:padding="12dp"
                                android:src="@drawable/ic_phone"
                                android:tint="#333333" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Khoảng cách & Thời gian (Metrics) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvRouteDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/base_map_duration_default"
                            android:textColor="@color/safe_green"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="8dp"
                            android:text="•"
                            android:textColor="#BDBDBD"
                            android:textSize="18sp"
                            tools:ignore="HardcodedText" />

                        <TextView
                            android:id="@+id/tvRouteDistance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/base_map_distance_default"
                            android:textColor="#666666"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- Nút Bắt đầu đi (CTA Chính) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartNavigation"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:text="@string/base_map_start_navigation"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="#34A853"
                        app:cornerRadius="16dp" />

                </LinearLayout>

                <!-- Vùng thiết lập lộ trình chi tiết (Mở rộng) -->
                <LinearLayout
                    android:id="@+id/layoutTopOverviewContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:paddingHorizontal="20dp"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginBottom="16dp" />

                    <!-- Điểm Bắt đầu -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_dot_green" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/tvStartAddress"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/base_map_start_address_loading"
                                android:textColor="#666666"
                                android:textSize="14sp" />


                        </LinearLayout>
                    </LinearLayout>

                    <!-- Điểm Kết thúc -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_dot_red" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/tvEndAddress"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/base_map_end_address_loading"
                                android:textColor="#666666"
                                android:textSize="14sp" />


                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRouteOptions"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="64dp"
                        android:paddingVertical="8dp"
                        android:layout_marginTop="24dp"
                        android:text="@string/base_map_route_options"
                        android:textColor="#333333"
                        app:backgroundTint="#F5F5F5"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_chevron_right"
                        app:iconGravity="textEnd"
                        app:iconTint="#333333" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCalculateRoute"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/base_map_calculate"
                        android:textStyle="bold"
                        app:backgroundTint="#4285F4"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDevSimulate"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="end"
                        android:text="@string/base_map_dev_simulate"
                        android:textColor="#FF9800"
                        android:visibility="visible"
                        app:cornerRadius="12dp"
                        app:strokeColor="@color/warning_orange"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressRouting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:visibility="invisible"
                        app:indicatorColor="#4285F4"
                        app:trackColor="#E3F2FD"
                        app:trackCornerRadius="4dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="240dp">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSetStartPoint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:contentDescription="@string/base_map_set_start_point"
            android:src="@drawable/ic_dot_green"
            app:backgroundTint="@color/white"
            app:elevation="6dp"
            app:fabSize="normal"
            app:layout_constraintBottom_toTopOf="@+id/btnSetEndPoint"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="#34A853" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSetEndPoint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:contentDescription="@string/base_map_set_end_point"
            android:src="@drawable/ic_dot_red"
            app:backgroundTint="@color/white"
            app:elevation="6dp"
            app:fabSize="normal"
            app:layout_constraintBottom_toTopOf="@+id/fabRecenterCurrentLocation"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="#EA4335" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabRecenterCurrentLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:contentDescription="@string/base_map_recenter_current_location_desc"
            android:src="@drawable/ic_map_pin"
            app:backgroundTint="@color/white"
            app:elevation="6dp"
            app:fabSize="normal"
            app:layout_constraintBottom_toTopOf="@+id/fabOpenControlPanel"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="#4285F4" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabOpenControlPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:contentDescription="@string/base_map_reopen_control_panel_desc"
            android:src="@drawable/ic_map"
            android:visibility="gone"
            app:backgroundTint="@color/white"
            app:elevation="6dp"
            app:fabSize="normal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="#34A853" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    

    <FrameLayout
        android:id="@+id/childContentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/hubSearchNavigationView"
        android:layout_width="340dp"
        android:layout_height="match_parent"
        android:layout_gravity="start">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/hubSearchFragmentContainer"
            android:name="com.drc.aidbridge.ui.map.feature.hub.HubSearchDrawerFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>

