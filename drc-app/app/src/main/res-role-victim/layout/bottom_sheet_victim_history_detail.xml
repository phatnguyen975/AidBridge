<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_surface"
    android:orientation="vertical"
    android:padding="@dimen/spacing_md">

    <View
        android:layout_width="@dimen/victim_history_sheet_handle_width"
        android:layout_height="@dimen/victim_history_sheet_handle_height"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/spacing_md"
        android:background="@color/border_default" />

    <TextView
        android:id="@+id/tvSheetTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/victim_history_detail_title"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_lg"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:background="@color/border_default" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/victim_history_sheet_min_height">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/victim_history_detail_section_request"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetailBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:lineSpacingExtra="@dimen/victim_history_detail_line_spacing_extra"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
