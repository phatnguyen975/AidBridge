<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardBackgroundColor="@color/volunteer_map_instruction_card_bg"
    app:cardCornerRadius="@dimen/radius_md"
    app:strokeColor="@color/volunteer_map_instruction_card_stroke"
    app:strokeWidth="@dimen/volunteer_map_instruction_stroke">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_sm">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="@dimen/volunteer_map_instruction_order_size"
            android:layout_height="@dimen/volunteer_map_instruction_order_size"
            app:cardBackgroundColor="@color/volunteer_map_instruction_order_bg"
            app:cardCornerRadius="@dimen/radius_full">

            <TextView
                android:id="@+id/tvInstructionOrder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvInstructionCommand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/volunteer_acceptance_text_primary"
                android:textSize="@dimen/text_md"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvInstructionMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:textColor="@color/volunteer_acceptance_text_secondary"
                android:textSize="@dimen/text_sm" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
