<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/volunteer_dashboard_padding">

        <!-- User Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardUserInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="@dimen/volunteer_dashboard_card_corner_radius"
            app:cardElevation="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/volunteer_dashboard_padding">

                <FrameLayout
                    android:id="@+id/frameAvatar"
                    android:layout_width="@dimen/volunteer_dashboard_avatar_size"
                    android:layout_height="@dimen/volunteer_dashboard_avatar_size"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/volunteer_dashboard_avatar_inner_padding"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_launcher_background"
                        app:shapeAppearanceOverlay="@style/CircleAppearance"
                        app:strokeColor="@color/white"
                        app:strokeWidth="@dimen/volunteer_dashboard_avatar_stroke_width" />

                    <View
                        android:id="@+id/viewStatusIndicator"
                        android:layout_width="@dimen/volunteer_dashboard_status_indicator_size"
                        android:layout_height="@dimen/volunteer_dashboard_status_indicator_size"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="@dimen/volunteer_dashboard_status_indicator_margin"
                        android:layout_marginBottom="@dimen/volunteer_dashboard_status_indicator_margin"
                        android:background="@drawable/bg_circle_status_online" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/volunteer_dashboard_padding"
                    android:text="@string/volunteer_dashboard_user_name_placeholder"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/volunteer_dashboard_text_user_name_size"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toTopOf="@id/tvUserRole"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/frameAvatar"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_chainStyle="packed" />

                <TextView
                    android:id="@+id/tvUserRole"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/volunteer_dashboard_padding"
                    android:layout_marginTop="@dimen/volunteer_dashboard_status_indicator_margin"
                    android:text="@string/volunteer_dashboard_user_role_placeholder"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/volunteer_dashboard_text_user_role_size"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/frameAvatar"
                    app:layout_constraintTop_toBottomOf="@id/tvUserName" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/volunteer_dashboard_padding"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="@dimen/volunteer_dashboard_card_corner_radius"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/cardUserInfo"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/volunteer_dashboard_padding">

                <TextView
                    android:id="@+id/tvStatusTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/volunteer_dashboard_status_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/volunteer_dashboard_section_title_size"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvStatusDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/volunteer_dashboard_status_indicator_margin"
                    android:text="@string/volunteer_dashboard_status_online_placeholder"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/volunteer_dashboard_status_desc_size"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvStatusTitle" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchOnlineStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:layout_constraintBottom_toBottomOf="@id/tvStatusDescription"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvStatusTitle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/volunteer_dashboard_padding"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/tvStatusDescription">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReady"
                        style="@style/Widget.MaterialComponents.Button.Icon"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:backgroundTint="@color/bg_surface_elevated"
                        android:text="@string/volunteer_dashboard_btn_ready"
                        android:textAllCaps="false"
                        android:textColor="@color/safe_green"
                        app:cornerRadius="@dimen/volunteer_dashboard_button_corner_radius"
                        app:icon="@drawable/ic_check_circle"
                        app:iconTint="@color/safe_green" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOffline"
                        style="@style/Widget.MaterialComponents.Button.Icon"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:backgroundTint="@color/bg_surface_elevated"
                        android:text="@string/volunteer_dashboard_btn_offline"
                        android:textAllCaps="false"
                        android:textColor="@color/text_secondary"
                        app:cornerRadius="@dimen/volunteer_dashboard_button_corner_radius"
                        app:icon="@drawable/bg_circle_status_offline"
                        app:iconTint="@color/text_secondary" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Stats Row -->
        <LinearLayout
            android:id="@+id/layoutStats"
            android:layout_width="match_parent"
            android:layout_height="@dimen/volunteer_dashboard_stats_row_height"
            android:layout_marginTop="@dimen/volunteer_dashboard_padding"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/cardStatus">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCurrentMission"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/color_primary_variant"
                app:cardCornerRadius="@dimen/volunteer_dashboard_card_corner_radius"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/volunteer_dashboard_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/volunteer_dashboard_current_mission_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/volunteer_dashboard_text_user_name_size"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="@dimen/volunteer_dashboard_icon_size"
                        android:layout_height="@dimen/volunteer_dashboard_icon_size"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:alpha="0.5"
                        android:src="@drawable/ic_assignment" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCompleted"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="@dimen/volunteer_dashboard_card_corner_radius"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/volunteer_dashboard_padding">

                    <TextView
                        android:id="@+id/tvCompletedLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/volunteer_dashboard_completed_label"
                        android:textColor="@color/safe_green"
                        android:textSize="@dimen/volunteer_dashboard_status_desc_size"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvCompletedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/volunteer_dashboard_completed_count_placeholder"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/volunteer_dashboard_completed_count_size"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <ImageView
                        android:layout_width="@dimen/volunteer_dashboard_icon_size"
                        android:layout_height="@dimen/volunteer_dashboard_icon_size"
                        android:src="@drawable/ic_check_circle"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:tint="@color/safe_green" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Notifications Header -->
        <TextView
            android:id="@+id/tvNotifTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/volunteer_dashboard_notif_title"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/volunteer_dashboard_section_title_size"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutStats" />

        <TextView
            android:id="@+id/tvSeeAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/volunteer_dashboard_see_all"
            android:textColor="@color/text_link"
            android:textSize="@dimen/volunteer_dashboard_status_desc_size"
            app:layout_constraintBottom_toBottomOf="@id/tvNotifTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvNotifTitle" />

        <!-- Notification Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEmergency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/volunteer_dashboard_padding"
            app:cardBackgroundColor="@color/color_primary_variant"
            app:cardCornerRadius="@dimen/volunteer_dashboard_card_corner_radius"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/tvNotifTitle"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/volunteer_dashboard_padding">

                <ImageView
                    android:id="@+id/ivNotifIcon"
                    android:layout_width="@dimen/volunteer_dashboard_notification_icon_size"
                    android:layout_height="@dimen/volunteer_dashboard_notification_icon_size"
                    android:background="@drawable/bg_circle_icon"
                    android:padding="@dimen/volunteer_dashboard_notification_icon_padding"
                    android:src="@drawable/ic_wifi_tethering"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/text_primary" />

                <TextView
                    android:id="@+id/tvEmergencyTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/volunteer_dashboard_padding"
                    android:text="@string/volunteer_dashboard_emergency_title"
                    android:textColor="@color/sos_red"
                    android:textSize="@dimen/volunteer_dashboard_section_title_size"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/ivNotifIcon"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvEmergencyDetails"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/volunteer_dashboard_padding"
                    android:layout_marginTop="@dimen/volunteer_dashboard_status_indicator_margin"
                    android:text="@string/volunteer_dashboard_emergency_details_placeholder"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/volunteer_dashboard_text_user_role_size"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/ivNotifIcon"
                    app:layout_constraintTop_toBottomOf="@id/tvEmergencyTitle" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/volunteer_dashboard_padding"
                    android:backgroundTint="@color/white"
                    android:text="@string/volunteer_dashboard_btn_details"
                    android:textAllCaps="false"
                    android:textColor="@color/color_primary_variant"
                    app:cornerRadius="@dimen/volunteer_dashboard_button_corner_radius"
                    app:layout_constraintTop_toBottomOf="@id/tvEmergencyDetails" />

                <ImageView
                    android:layout_width="@dimen/volunteer_dashboard_notification_overlay_icon_size"
                    android:layout_height="@dimen/volunteer_dashboard_notification_overlay_icon_size"
                    android:alpha="0.1"
                    android:rotation="-15"
                    android:src="@drawable/ic_campaign"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Logout Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="@string/volunteer_dashboard_btn_logout"
            android:textAllCaps="false"
            android:textColor="@color/sos_red"
            app:icon="@drawable/ic_logout"
            app:iconTint="@color/sos_red"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardEmergency" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
