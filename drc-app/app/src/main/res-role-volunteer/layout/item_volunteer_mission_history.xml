<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardMissionHistory"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_sm"
    app:cardBackgroundColor="@color/bg_surface"
    app:cardCornerRadius="@dimen/radius_md"
    app:strokeColor="@color/border_default"
    app:strokeWidth="@dimen/volunteer_mission_history_card_stroke_width">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clMissionHistoryContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_md">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMissionCategoryBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/sos_red"
            app:cardCornerRadius="@dimen/radius_full"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/spacing_sm"
                android:paddingTop="@dimen/spacing_xs"
                android:paddingEnd="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_xs">

                <ImageView
                    android:id="@+id/ivMissionCategoryIcon"
                    android:layout_width="@dimen/volunteer_mission_history_badge_icon_size"
                    android:layout_height="@dimen/volunteer_mission_history_badge_icon_size"
                    android:contentDescription="@string/volunteer_mission_history_category_icon_content_desc"
                    android:src="@android:drawable/ic_dialog_alert"
                    android:tint="@color/white" />

                <TextView
                    android:id="@+id/tvMissionCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/volunteer_mission_history_category_emergency"
                    android:textAllCaps="true"
                    android:textColor="@color/white"
                    android:textSize="@dimen/volunteer_mission_history_badge_text_size" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvMissionLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:fontFamily="sans-serif"
            android:text="@string/volunteer_mission_history_location_placeholder"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/volunteer_mission_history_location_text_size"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardMissionCategoryBadge" />

        <TextView
            android:id="@+id/tvMissionDateTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="@string/volunteer_mission_history_datetime_placeholder"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/volunteer_mission_history_datetime_text_size"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMissionLocation" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivMissionPhoto"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/spacing_sm"
            android:contentDescription="@string/volunteer_mission_history_photo_content_desc"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="16:9"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMissionDateTime"
            app:shapeAppearance="?attr/shapeAppearanceMediumComponent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>