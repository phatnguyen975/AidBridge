<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardMissionHistory"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_sm"
    app:cardBackgroundColor="#3182CE"
    app:cardCornerRadius="@dimen/radius_md"
    app:strokeColor="#63B3ED"
    app:strokeWidth="@dimen/volunteer_mission_history_card_stroke_width">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clMissionHistoryContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_md">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMissionCategoryBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/sos_red"
            app:cardCornerRadius="@dimen/radius_full"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/spacing_sm"
                android:paddingTop="@dimen/spacing_xs"
                android:paddingEnd="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_xs">

                <ImageView
                    android:id="@+id/ivMissionCategoryIcon"
                    android:layout_width="@dimen/volunteer_mission_history_badge_icon_size"
                    android:layout_height="@dimen/volunteer_mission_history_badge_icon_size"
                    android:src="@android:drawable/ic_dialog_alert"
                    android:tint="@color/white" />

                <TextView
                    android:id="@+id/tvMissionCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:fontFamily="sans-serif-medium"
                    android:text="RESCUE"
                    android:textAllCaps="true"
                    android:textColor="@color/white"
                    android:textSize="@dimen/volunteer_mission_history_badge_text_size" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMissionStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#DBEAFE"
            app:cardCornerRadius="@dimen/radius_full"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvMissionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/spacing_sm"
                android:paddingTop="@dimen/spacing_xs"
                android:paddingEnd="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_xs"
                android:fontFamily="sans-serif-medium"
                android:text="CANCELLED"
                android:textAllCaps="true"
                android:textColor="#1D4ED8"
                android:textSize="@dimen/volunteer_mission_history_badge_text_size" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Đưa Mã Nhiệm Vụ lên làm Header -->
        <TextView
            android:id="@+id/tvMissionCodeName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="MÃ: MISSION-ID-123"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardMissionCategoryBadge" />

        <TextView
            android:id="@+id/tvMissionLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Địa chỉ: --"
            android:textColor="#E2E8F0"
            android:textSize="@dimen/volunteer_mission_history_location_text_size"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMissionCodeName" />

        <TextView
            android:id="@+id/tvMissionDateTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Thời gian: --"
            android:textColor="#E2E8F0"
            android:textSize="@dimen/volunteer_mission_history_datetime_text_size"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMissionLocation" />

        <TextView
            android:id="@+id/tvMissionRadius"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Bán kính: --"
            android:textColor="#E2E8F0"
            android:textSize="@dimen/volunteer_mission_history_datetime_text_size"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMissionDateTime" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivMissionPhoto"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/spacing_sm"
            android:scaleType="centerCrop"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="16:9"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMissionRadius"
            app:shapeAppearance="?attr/shapeAppearanceMediumComponent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
