<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/volunteer_acceptance_bg">

    <org.osmdroid.views.MapView
        android:id="@+id/osmMapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/volunteer_map_map_overlay" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardNavigationHud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:visibility="gone"
        app:cardBackgroundColor="@color/volunteer_map_hud_bg"
        app:cardCornerRadius="@dimen/radius_lg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <TextView
                android:id="@+id/tvHudPrimaryInstruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/volunteer_map_instruction_continue"
                android:textColor="@color/white"
                android:textSize="@dimen/text_md"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHudSecondaryInstruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/volunteer_map_hud_waiting"
                android:textColor="@color/volunteer_acceptance_text_secondary"
                android:textSize="@dimen/text_sm" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/layoutNavigationActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_md"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelMission"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/volunteer_map_action_button_height"
            android:text="@string/volunteer_map_cancel_mission"
            android:textAllCaps="false"
            app:backgroundTint="@color/sos_red"
            app:cornerRadius="@dimen/radius_md"
            app:icon="@drawable/ic_close"
            app:iconTint="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnArrivedMission"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/volunteer_map_action_button_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="@string/volunteer_map_arrived"
            android:textAllCaps="false"
            app:backgroundTint="@color/safe_green"
            app:cornerRadius="@dimen/radius_md"
            app:icon="@drawable/ic_check_circle"
            app:iconTint="@color/white" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabOpenControlPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/volunteer_map_reopen_fab_bottom_margin"
        android:contentDescription="@string/volunteer_map_reopen_control_panel_desc"
        android:src="@drawable/ic_map"
        android:tint="@color/white"
        android:visibility="gone"
        app:backgroundTint="@color/volunteer_map_instruction_card_bg" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTopOverview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_md"
        android:elevation="12dp"
        app:behavior_draggable="true"
        app:behavior_fitToContents="false"
        app:behavior_hideable="false"
        app:behavior_peekHeight="@dimen/volunteer_map_sheet_peek_height"
        app:behavior_skipCollapsed="false"
        app:cardBackgroundColor="@color/volunteer_map_panel_bg"
        app:cardCornerRadius="@dimen/volunteer_map_sheet_corner_radius"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:strokeColor="@color/volunteer_map_panel_stroke"
        app:strokeWidth="@dimen/volunteer_map_panel_stroke">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="ifContentScrolls"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/spacing_md"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingEnd="@dimen/spacing_md"
                android:paddingBottom="@dimen/spacing_md">

                <View
                    android:layout_width="@dimen/volunteer_map_drag_handle_width"
                    android:layout_height="@dimen/volunteer_map_drag_handle_height"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_map_drag_handle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvMapTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/volunteer_map_title"
                        android:textColor="@color/volunteer_acceptance_text_primary"
                        android:textSize="@dimen/text_xl"
                        android:textStyle="bold" />

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/spacing_sm">

                        <ImageView
                            android:id="@+id/ivDevAvatar"
                            android:layout_width="@dimen/volunteer_map_avatar_size"
                            android:layout_height="@dimen/volunteer_map_avatar_size"
                            android:background="@drawable/bg_circle_icon"
                            android:contentDescription="@string/volunteer_map_dev_avatar_desc"
                            android:padding="@dimen/spacing_xs"
                            android:src="@drawable/ic_person"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/tvDevHintSign"
                            android:layout_width="@dimen/volunteer_map_dev_hint_size"
                            android:layout_height="@dimen/volunteer_map_dev_hint_size"
                            android:layout_gravity="end|top"
                            android:layout_marginTop="-4dp"
                            android:layout_marginEnd="-4dp"
                            android:background="@drawable/bg_circle_icon"
                            android:gravity="center"
                            android:text="@string/volunteer_map_dev_sign"
                            android:textColor="@color/white"
                            android:textSize="@dimen/text_xs"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <ImageButton
                        android:id="@+id/btnToggleTopPanel"
                        android:layout_width="@dimen/volunteer_map_toggle_icon_size"
                        android:layout_height="@dimen/volunteer_map_toggle_icon_size"
                        android:background="@android:color/transparent"
                        android:contentDescription="@string/volunteer_map_toggle_panel_desc"
                        android:padding="@dimen/spacing_xs"
                        android:src="@drawable/ic_arrow_down"
                        android:tint="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvPrimaryDestination"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:maxLines="2"
                        android:text="@string/volunteer_map_end_address_loading_short"
                        android:textColor="@color/volunteer_acceptance_text_primary"
                        android:textSize="@dimen/volunteer_map_destination_text_size"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btnCallVictim"
                        android:layout_width="@dimen/volunteer_map_call_icon_size"
                        android:layout_height="@dimen/volunteer_map_call_icon_size"
                        android:background="@drawable/bg_circle_icon"
                        android:contentDescription="@string/volunteer_map_call_content_desc"
                        android:padding="@dimen/spacing_sm"
                        android:src="@drawable/ic_phone"
                        android:tint="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvRouteDistance"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/volunteer_map_distance_default"
                        android:textColor="@color/volunteer_acceptance_text_primary"
                        android:textSize="@dimen/volunteer_map_metric_text_size"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvRouteDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/volunteer_map_duration_default"
                        android:textColor="@color/volunteer_acceptance_text_primary"
                        android:textSize="@dimen/volunteer_map_metric_text_size"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartNavigation"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/volunteer_map_primary_cta_height"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/volunteer_map_start_navigation"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:backgroundTint="@color/safe_green"
                    app:cornerRadius="@dimen/radius_lg" />

                <LinearLayout
                    android:id="@+id/layoutTopOverviewContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSetStartPoint"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/volunteer_map_route_field_height"
                        android:gravity="start|center_vertical"
                        android:paddingStart="@dimen/spacing_md"
                        android:text="@string/volunteer_map_set_start_point"
                        android:textAllCaps="false"
                        android:textColor="@color/volunteer_acceptance_text_primary"
                        app:backgroundTint="@color/volunteer_map_field_bg"
                        app:cornerRadius="@dimen/radius_lg"
                        app:icon="@drawable/ic_dot_green"
                        app:iconGravity="textStart"
                        app:iconPadding="@dimen/spacing_sm"
                        app:iconTint="@null" />

                    <TextView
                        android:id="@+id/tvStartAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/volunteer_map_start_address_loading"
                        android:textColor="@color/volunteer_acceptance_text_secondary"
                        android:textSize="@dimen/text_sm" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSetEndPoint"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/volunteer_map_route_field_height"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:gravity="start|center_vertical"
                        android:paddingStart="@dimen/spacing_md"
                        android:text="@string/volunteer_map_set_end_point"
                        android:textAllCaps="false"
                        android:textColor="@color/volunteer_acceptance_text_primary"
                        app:backgroundTint="@color/volunteer_map_field_bg"
                        app:cornerRadius="@dimen/radius_lg"
                        app:icon="@drawable/ic_dot_red"
                        app:iconGravity="textStart"
                        app:iconPadding="@dimen/spacing_sm"
                        app:iconTint="@null" />

                    <TextView
                        android:id="@+id/tvEndAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/volunteer_map_end_address_loading"
                        android:textColor="@color/volunteer_acceptance_text_secondary"
                        android:textSize="@dimen/text_sm" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRouteOptions"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/volunteer_map_calculate_button_height"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/volunteer_map_route_options"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/volunteer_map_instruction_card_bg"
                        app:cornerRadius="@dimen/radius_lg"
                        app:icon="@drawable/ic_chevron_right"
                        app:iconGravity="textEnd"
                        app:iconTint="@color/white" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCalculateRoute"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/volunteer_map_calculate_button_height"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/volunteer_map_calculate"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:backgroundTint="@color/volunteer_acceptance_accept_button_bg"
                        app:cornerRadius="@dimen/radius_lg" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDevSimulate"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/volunteer_map_calculate_button_height"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/volunteer_map_dev_simulate"
                        android:textAllCaps="false"
                        android:textColor="@color/warning_orange"
                        android:visibility="gone"
                        app:backgroundTint="@android:color/transparent"
                        app:cornerRadius="@dimen/radius_lg"
                        app:strokeColor="@color/warning_orange"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressRouting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:visibility="gone"
                        app:indicatorColor="@color/volunteer_acceptance_accept_button_bg"
                        app:trackColor="@color/volunteer_map_progress_track" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabRecenterCurrentLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start|bottom"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/volunteer_map_reopen_fab_bottom_margin"
        android:contentDescription="@string/volunteer_map_recenter_current_location_desc"
        android:src="@drawable/ic_map_pin"
        android:tint="@color/white"
        app:backgroundTint="@color/volunteer_map_instruction_card_bg" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
