<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/volunteer_acceptance_bg">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarDeliveryMission"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/volunteer_acceptance_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/volunteer_delivery_mission_title"
            android:textColor="@color/volunteer_acceptance_text_primary"
            android:textSize="@dimen/volunteer_current_mission_toolbar_title_size"
            android:textStyle="bold" />
    </com.google.android.material.appbar.MaterialToolbar>

    <LinearLayout
        android:id="@+id/layoutDeliveryActionContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_md"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnArrivedDepot"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/volunteer_sos_acceptance_button_height"
            android:text="@string/volunteer_delivery_mission_btn_arrived_depot"
            android:textAllCaps="false"
            android:textColor="@color/volunteer_acceptance_text_primary"
            android:textSize="@dimen/volunteer_sos_acceptance_button_text_size"
            android:textStyle="bold"
            app:backgroundTint="@color/volunteer_acceptance_accept_button_bg"
            app:cornerRadius="@dimen/volunteer_sos_acceptance_button_radius"
            app:icon="@drawable/ic_check_circle"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/spacing_sm"
            app:iconSize="@dimen/volunteer_sos_acceptance_button_icon_size"
            app:iconTint="@color/volunteer_acceptance_text_primary" />

        <TextView
            android:id="@+id/tvArrivedDepotHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="center"
            android:text="@string/volunteer_delivery_mission_arrived_hint"
            android:textColor="@color/volunteer_acceptance_text_secondary"
            android:textSize="@dimen/text_sm" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollDeliveryMission"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/layoutDeliveryActionContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarDeliveryMission">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_md"
            android:paddingTop="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_md">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDeliveryProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/volunteer_acceptance_mission_card_bg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:strokeColor="@color/volunteer_acceptance_decline_button_stroke"
                app:strokeWidth="@dimen/volunteer_mission_history_card_stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDeliveryTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/volunteer_delivery_mission_progress_title"
                                android:textColor="@color/volunteer_acceptance_text_primary"
                                android:textSize="@dimen/volunteer_delivery_mission_title_size"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvDeliveryOrderCode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_xs"
                                android:text="@string/volunteer_delivery_mission_order_code"
                                android:textColor="@color/volunteer_acceptance_text_secondary"
                                android:textSize="@dimen/text_sm" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvDeliveryProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="@string/volunteer_delivery_mission_progress_value"
                            android:textColor="@color/volunteer_acceptance_accept_button_bg"
                            android:textSize="@dimen/volunteer_delivery_mission_progress_text_size"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutProgressSegments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="@dimen/volunteer_delivery_mission_progress_segment_height"
                            android:layout_weight="1"
                            android:background="@color/volunteer_acceptance_accept_button_bg" />

                        <View
                            android:layout_width="@dimen/spacing_xs"
                            android:layout_height="1dp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="@dimen/volunteer_delivery_mission_progress_segment_height"
                            android:layout_weight="1"
                            android:background="@color/volunteer_acceptance_decline_button_stroke" />

                        <View
                            android:layout_width="@dimen/spacing_xs"
                            android:layout_height="1dp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="@dimen/volunteer_delivery_mission_progress_segment_height"
                            android:layout_weight="1"
                            android:background="@color/volunteer_acceptance_decline_button_stroke" />

                        <View
                            android:layout_width="@dimen/spacing_xs"
                            android:layout_height="1dp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="@dimen/volunteer_delivery_mission_progress_segment_height"
                            android:layout_weight="1"
                            android:background="@color/volunteer_acceptance_decline_button_stroke" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDeliveryMap"
                android:layout_width="match_parent"
                android:layout_height="@dimen/volunteer_delivery_mission_map_height"
                android:layout_marginTop="@dimen/spacing_md"
                app:cardBackgroundColor="@color/volunteer_acceptance_map_placeholder_bg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:strokeColor="@color/volunteer_acceptance_decline_button_stroke"
                app:strokeWidth="@dimen/volunteer_mission_history_card_stroke_width">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/volunteer_delivery_mission_map_placeholder"
                    android:textColor="@color/volunteer_acceptance_text_secondary"
                    android:textSize="@dimen/text_md"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvTimelineTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/volunteer_delivery_mission_timeline_title"
                android:textAllCaps="true"
                android:textColor="@color/volunteer_acceptance_text_secondary"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutDeliveryTimeline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="@dimen/volunteer_delivery_mission_timeline_indicator_width"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="@dimen/volunteer_delivery_mission_timeline_icon_size"
                            android:layout_height="@dimen/volunteer_delivery_mission_timeline_icon_size"
                            app:cardBackgroundColor="@color/volunteer_acceptance_accept_button_bg"
                            app:cardCornerRadius="@dimen/radius_full">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/volunteer_delivery_mission_step_icon_desc"
                                android:padding="@dimen/spacing_sm"
                                android:src="@android:drawable/ic_menu_mylocation"
                                app:tint="@color/volunteer_acceptance_text_primary" />
                        </com.google.android.material.card.MaterialCardView>

                        <View
                            android:layout_width="@dimen/volunteer_delivery_mission_timeline_connector_width"
                            android:layout_height="@dimen/volunteer_delivery_mission_timeline_connector_height"
                            android:background="@color/volunteer_acceptance_accept_button_bg" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:layout_marginBottom="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/volunteer_delivery_mission_step_1_title"
                            android:textColor="@color/volunteer_acceptance_accept_button_bg"
                            android:textSize="@dimen/text_lg"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/volunteer_delivery_mission_step_1_desc"
                            android:textColor="@color/volunteer_acceptance_text_secondary"
                            android:textSize="@dimen/text_md" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="@dimen/volunteer_delivery_mission_timeline_indicator_width"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="@dimen/volunteer_delivery_mission_timeline_icon_size"
                            android:layout_height="@dimen/volunteer_delivery_mission_timeline_icon_size"
                            app:cardBackgroundColor="@color/volunteer_acceptance_decline_button_stroke"
                            app:cardCornerRadius="@dimen/radius_full">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/volunteer_delivery_mission_step_icon_desc"
                                android:padding="@dimen/spacing_sm"
                                android:src="@android:drawable/ic_menu_upload"
                                app:tint="@color/volunteer_acceptance_text_secondary" />
                        </com.google.android.material.card.MaterialCardView>

                        <View
                            android:layout_width="@dimen/volunteer_delivery_mission_timeline_connector_width"
                            android:layout_height="@dimen/volunteer_delivery_mission_timeline_connector_height"
                            android:background="@color/volunteer_acceptance_decline_button_stroke" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:layout_marginBottom="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:alpha="0.65"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/volunteer_delivery_mission_step_2_title"
                            android:textColor="@color/volunteer_acceptance_text_primary"
                            android:textSize="@dimen/text_lg"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/volunteer_delivery_mission_step_2_desc"
                            android:textColor="@color/volunteer_acceptance_text_secondary"
                            android:textSize="@dimen/text_md" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="@dimen/volunteer_delivery_mission_timeline_indicator_width"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="@dimen/volunteer_delivery_mission_timeline_icon_size"
                            android:layout_height="@dimen/volunteer_delivery_mission_timeline_icon_size"
                            app:cardBackgroundColor="@color/volunteer_acceptance_decline_button_stroke"
                            app:cardCornerRadius="@dimen/radius_full">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/volunteer_delivery_mission_step_icon_desc"
                                android:padding="@dimen/spacing_sm"
                                android:src="@android:drawable/ic_menu_myplaces"
                                app:tint="@color/volunteer_acceptance_text_secondary" />
                        </com.google.android.material.card.MaterialCardView>

                        <View
                            android:layout_width="@dimen/volunteer_delivery_mission_timeline_connector_width"
                            android:layout_height="@dimen/volunteer_delivery_mission_timeline_connector_height"
                            android:background="@color/volunteer_acceptance_decline_button_stroke" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:layout_marginBottom="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:alpha="0.65"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/volunteer_delivery_mission_step_3_title"
                            android:textColor="@color/volunteer_acceptance_text_primary"
                            android:textSize="@dimen/text_lg"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/volunteer_delivery_mission_step_3_desc"
                            android:textColor="@color/volunteer_acceptance_text_secondary"
                            android:textSize="@dimen/text_md" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="@dimen/volunteer_delivery_mission_timeline_indicator_width"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="@dimen/volunteer_delivery_mission_timeline_icon_size"
                            android:layout_height="@dimen/volunteer_delivery_mission_timeline_icon_size"
                            app:cardBackgroundColor="@color/volunteer_acceptance_decline_button_stroke"
                            app:cardCornerRadius="@dimen/radius_full">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/volunteer_delivery_mission_step_icon_desc"
                                android:padding="@dimen/spacing_sm"
                                android:src="@android:drawable/checkbox_on_background"
                                app:tint="@color/volunteer_acceptance_text_secondary" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:alpha="0.65"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/volunteer_delivery_mission_step_4_title"
                            android:textColor="@color/volunteer_acceptance_text_primary"
                            android:textSize="@dimen/text_lg"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/volunteer_delivery_mission_step_4_desc"
                            android:textColor="@color/volunteer_acceptance_text_secondary"
                            android:textSize="@dimen/text_md" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRecipientInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                app:cardBackgroundColor="@color/volunteer_acceptance_mission_card_bg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:strokeColor="@color/volunteer_acceptance_decline_button_stroke"
                app:strokeWidth="@dimen/volunteer_mission_history_card_stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="@dimen/volunteer_current_mission_header_icon_size"
                            android:layout_height="@dimen/volunteer_current_mission_header_icon_size"
                            android:contentDescription="@string/volunteer_delivery_mission_recipient_icon_desc"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:tint="@color/volunteer_current_mission_header_icon_tint" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:text="@string/volunteer_delivery_mission_recipient_title"
                            android:textAllCaps="true"
                            android:textColor="@color/volunteer_acceptance_text_primary"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/volunteer_delivery_mission_recipient_name_label"
                        android:textAllCaps="true"
                        android:textColor="@color/volunteer_acceptance_text_secondary"
                        android:textSize="@dimen/text_sm" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/volunteer_delivery_mission_recipient_name_value"
                        android:textColor="@color/volunteer_acceptance_text_primary"
                        android:textSize="@dimen/volunteer_delivery_mission_recipient_value_size"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/volunteer_delivery_mission_recipient_phone_label"
                        android:textAllCaps="true"
                        android:textColor="@color/volunteer_acceptance_text_secondary"
                        android:textSize="@dimen/text_sm" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/volunteer_delivery_mission_recipient_phone_value"
                        android:textColor="@color/volunteer_acceptance_text_primary"
                        android:textSize="@dimen/volunteer_delivery_mission_recipient_value_size"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/volunteer_delivery_mission_recipient_note_label"
                        android:textAllCaps="true"
                        android:textColor="@color/volunteer_acceptance_text_secondary"
                        android:textSize="@dimen/text_sm" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/volunteer_delivery_mission_recipient_note_value"
                        android:textColor="@color/volunteer_acceptance_text_primary"
                        android:textSize="@dimen/text_md" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDeliveryOrderDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                app:cardBackgroundColor="@color/volunteer_acceptance_mission_card_bg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:strokeColor="@color/volunteer_acceptance_decline_button_stroke"
                app:strokeWidth="@dimen/volunteer_mission_history_card_stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/ivOrderDetailIcon"
                            android:layout_width="@dimen/volunteer_sos_acceptance_icon_size"
                            android:layout_height="@dimen/volunteer_sos_acceptance_icon_size"
                            android:contentDescription="@string/volunteer_delivery_mission_order_detail_icon_desc"
                            android:padding="@dimen/spacing_sm"
                            android:src="@drawable/ic_truck"
                            app:tint="@color/volunteer_acceptance_text_secondary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:layout_weight="1"
                            android:text="@string/volunteer_delivery_mission_order_detail_title"
                            android:textColor="@color/volunteer_acceptance_text_primary"
                            android:textSize="@dimen/text_md"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewOrderDetail"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/volunteer_delivery_mission_btn_view_detail"
                        android:textAllCaps="false"
                        android:textColor="@color/volunteer_acceptance_text_primary"
                        app:backgroundTint="@color/volunteer_acceptance_accept_button_bg"
                        app:cornerRadius="@dimen/volunteer_sos_acceptance_button_radius" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>