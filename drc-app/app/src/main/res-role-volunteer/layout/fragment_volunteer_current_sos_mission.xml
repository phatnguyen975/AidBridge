<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/volunteer_acceptance_bg">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarCurrentMission"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/volunteer_acceptance_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/volunteer_current_mission_title"
                android:textColor="@color/volunteer_acceptance_text_primary"
                android:textSize="@dimen/volunteer_current_mission_toolbar_title_size"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.MaterialToolbar>

    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/white"
        android:alpha="0.1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarCurrentMission" />

    <LinearLayout
        android:id="@+id/bottomActionContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_md"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnArrived"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/volunteer_sos_acceptance_button_height"
            android:text="@string/volunteer_current_mission_btn_arrived"
            android:textAllCaps="false"
            android:textColor="@color/volunteer_acceptance_text_primary"
            android:textSize="@dimen/volunteer_sos_acceptance_button_text_size"
            android:textStyle="bold"
            app:backgroundTint="@color/volunteer_acceptance_accept_button_bg"
            app:cornerRadius="@dimen/volunteer_sos_acceptance_button_radius"
            app:icon="@drawable/ic_check_circle"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/spacing_sm"
            app:iconSize="@dimen/volunteer_sos_acceptance_button_icon_size"
            app:iconTint="@color/volunteer_acceptance_text_primary" />

        <TextView
            android:id="@+id/tvArrivedHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="center"
            android:text="@string/volunteer_current_mission_btn_hint"
            android:textColor="@color/volunteer_acceptance_text_secondary"
            android:textSize="@dimen/text_sm" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollCurrentMission"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomActionContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarCurrentMission">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_md">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMissionOverview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_md"
                app:cardBackgroundColor="@color/volunteer_acceptance_mission_card_bg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:strokeColor="@color/volunteer_acceptance_decline_button_stroke"
                app:strokeWidth="@dimen/volunteer_mission_history_card_stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/volunteer_acceptance_badge_urgent"
                            app:cardCornerRadius="@dimen/radius_full">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingStart="@dimen/spacing_sm"
                                android:paddingTop="@dimen/spacing_xs"
                                android:paddingEnd="@dimen/spacing_sm"
                                android:paddingBottom="@dimen/spacing_xs"
                                android:text="@string/volunteer_current_mission_badge_rescue"
                                android:textColor="@color/volunteer_acceptance_text_primary"
                                android:textSize="@dimen/text_xs"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            app:cardBackgroundColor="@color/volunteer_current_mission_urgent_label_bg"
                            app:cardCornerRadius="@dimen/radius_full">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingStart="@dimen/spacing_sm"
                                android:paddingTop="@dimen/spacing_xs"
                                android:paddingEnd="@dimen/spacing_sm"
                                android:paddingBottom="@dimen/spacing_xs"
                                android:text="@string/volunteer_current_mission_urgent_label"
                                android:textColor="@color/volunteer_current_mission_urgent_label_text"
                                android:textSize="@dimen/text_xs"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/volunteer_current_mission_request_title"
                        android:textColor="@color/volunteer_acceptance_text_primary"
                        android:textSize="@dimen/volunteer_current_mission_request_title_size"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMissionCodeValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="N/A"
                        android:textColor="@color/volunteer_acceptance_text_secondary"
                        android:textSize="@dimen/text_sm"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/volunteer_current_mission_area"
                        android:textColor="@color/volunteer_acceptance_text_secondary"
                        android:textSize="@dimen/text_md" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMapPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="@dimen/volunteer_current_mission_map_height"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_md"
                app:cardBackgroundColor="@color/volunteer_acceptance_map_placeholder_bg"
                app:cardCornerRadius="@dimen/radius_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/volunteer_current_mission_map_placeholder"
                    android:textColor="@color/volunteer_acceptance_text_secondary"
                    android:textSize="@dimen/text_md"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMissionProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_md"
                app:cardBackgroundColor="@color/volunteer_acceptance_mission_card_bg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:strokeColor="@color/volunteer_acceptance_decline_button_stroke"
                app:strokeWidth="@dimen/volunteer_mission_history_card_stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/volunteer_current_mission_progress_start"
                            android:textColor="@color/volunteer_acceptance_text_primary"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressMissionState"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:layout_weight="1"
                            android:max="100"
                            android:progress="45"
                            app:indicatorColor="@color/volunteer_acceptance_accept_button_bg"
                            app:trackColor="@color/volunteer_acceptance_decline_button_stroke"
                            app:trackCornerRadius="@dimen/radius_full" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/volunteer_current_mission_progress_end"
                            android:textColor="@color/volunteer_acceptance_text_primary"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ProgressBar
                            android:layout_width="@dimen/volunteer_current_mission_loading_size"
                            android:layout_height="@dimen/volunteer_current_mission_loading_size"
                            android:indeterminate="true" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:text="@string/volunteer_current_mission_status_text"
                            android:textColor="@color/volunteer_acceptance_text_secondary"
                            android:textSize="@dimen/text_sm" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardVictimDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_md"
                app:cardBackgroundColor="@color/volunteer_acceptance_mission_card_bg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:strokeColor="@color/volunteer_acceptance_decline_button_stroke"
                app:strokeWidth="@dimen/volunteer_mission_history_card_stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="@dimen/volunteer_current_mission_header_icon_size"
                            android:layout_height="@dimen/volunteer_current_mission_header_icon_size"
                            android:contentDescription="@string/volunteer_current_mission_victim_info_icon_desc"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:tint="@color/volunteer_current_mission_header_icon_tint" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:text="@string/volunteer_current_mission_victim_info_title"
                            android:textColor="@color/volunteer_acceptance_text_secondary"
                            android:textSize="@dimen/text_md"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvVictimName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/volunteer_current_mission_victim_name"
                                android:textColor="@color/volunteer_acceptance_text_primary"
                                android:textSize="@dimen/text_md"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvVictimPhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_sm"
                                android:text="@string/volunteer_current_mission_victim_phone"
                                android:textColor="@color/volunteer_acceptance_text_primary"
                                android:textSize="@dimen/text_md"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/btnCallVictim"
                            android:layout_width="@dimen/volunteer_current_mission_toolbar_icon_button_size"
                            android:layout_height="@dimen/volunteer_current_mission_toolbar_icon_button_size"
                            android:background="@android:color/transparent"
                            android:contentDescription="@string/volunteer_current_mission_call_victim_desc"
                            android:padding="@dimen/spacing_sm"
                            android:src="@android:drawable/ic_menu_call"
                            app:tint="@color/volunteer_acceptance_accept_button_bg" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvVictimAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/volunteer_current_mission_victim_address"
                        android:textColor="@color/volunteer_acceptance_text_primary"
                        android:textSize="@dimen/text_sm" />

                    <TextView
                        android:id="@+id/tvVictimLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="Tọa độ: N/A"
                        android:textColor="@color/volunteer_acceptance_text_primary"
                        android:textSize="@dimen/text_sm" />

                    <TextView
                        android:id="@+id/tvRadiusKm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="Bán kính cứu trợ: N/A"
                        android:textColor="@color/volunteer_acceptance_text_primary"
                        android:textSize="@dimen/text_sm" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/volunteer_current_mission_health_label"
                            android:textColor="@color/volunteer_acceptance_text_secondary"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="@dimen/volunteer_current_mission_health_dot_size"
                                android:layout_height="@dimen/volunteer_current_mission_health_dot_size"
                                app:cardBackgroundColor="@color/volunteer_current_mission_health_dot"
                                app:cardCornerRadius="@dimen/radius_full" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_sm"
                                android:text="@string/volunteer_current_mission_health_value"
                                android:textColor="@color/volunteer_acceptance_text_primary"
                                android:textSize="@dimen/text_md"
                                android:textStyle="bold"/>

                        </LinearLayout>


                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        app:cardBackgroundColor="@color/volunteer_current_mission_note_bg"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:strokeColor="@color/volunteer_current_mission_note_stroke"
                        app:strokeWidth="@dimen/volunteer_mission_history_card_stroke_width">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/volunteer_current_mission_important_note_label"
                                android:textColor="@color/volunteer_current_mission_note_stroke"
                                android:textSize="@dimen/text_xs"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvImportantNoteValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_sm"
                                android:text="@string/volunteer_current_mission_important_note_value"
                                android:textColor="@color/volunteer_acceptance_text_primary"
                                android:textSize="@dimen/text_sm" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
