<?xml version="1.0" encoding="utf-8"?>
<!--
    cb_tint.xml — Color state list for CheckBox buttonTint.
    - Checked state  : color_primary (#288DFA) — blue tick clearly visible on dark background
    - Unchecked state: border_input (#475569)  — gray border visible on dark background
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:color="@color/color_primary" android:state_checked="true" />
    <item android:color="@color/border_input" />
</selector>
