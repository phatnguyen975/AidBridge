<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_home.xml — Màn hình trang chủ sau khi đăng nhập thành công.
    Hiển thị thông tin người dùng (tên, email, vai trò) và nút đăng xuất.
    Được host bởi MainActivity (thay thế HomeActivity đã bị loại bỏ).
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Responsive guidelines -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.06" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_end"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.94" />

    <!-- Lời chào -->
    <TextView
        android:id="@+id/tv_greeting"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Xin chào,"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_md"
        android:layout_marginTop="@dimen/spacing_xl"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/gl_start"
        app:layout_constraintEnd_toStartOf="@id/gl_end" />

    <!-- Tên người dùng -->
    <TextView
        android:id="@+id/tv_user_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Người dùng"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_xxl"
        android:textStyle="bold"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_greeting"
        app:layout_constraintStart_toEndOf="@id/gl_start"
        app:layout_constraintEnd_toStartOf="@id/gl_end" />

    <!-- Card thông tin tài khoản -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_profile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xl"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/border_default"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/tv_user_name"
        app:layout_constraintStart_toEndOf="@id/gl_start"
        app:layout_constraintEnd_toStartOf="@id/gl_end">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_lg">

            <!-- Avatar tròn -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_avatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardBackgroundColor="@color/card_selected_bg"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_person"
                    app:tint="@color/color_primary"
                    android:contentDescription="Avatar" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Nhãn thông tin -->
            <TextView
                android:id="@+id/tv_info_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Thông tin tài khoản"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_xs"
                android:letterSpacing="0.1"
                android:layout_marginStart="@dimen/spacing_md"
                app:layout_constraintTop_toTopOf="@id/card_avatar"
                app:layout_constraintStart_toEndOf="@id/card_avatar"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Email -->
            <TextView
                android:id="@+id/tv_user_email"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="email@example.com"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md"
                android:layout_marginTop="2dp"
                android:layout_marginStart="@dimen/spacing_md"
                app:layout_constraintTop_toBottomOf="@id/tv_info_label"
                app:layout_constraintStart_toEndOf="@id/card_avatar"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Card vai trò -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_role"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        app:cardBackgroundColor="@color/card_selected_bg"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/border_selected"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/card_profile"
        app:layout_constraintStart_toEndOf="@id/gl_start"
        app:layout_constraintEnd_toStartOf="@id/gl_end">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vai trò: "
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_md" />

            <TextView
                android:id="@+id/tv_user_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GUEST"
                android:textColor="@color/color_primary"
                android:textSize="@dimen/text_md"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Nút đăng xuất -->
    <Button
        android:id="@+id/btn_logout"
        android:layout_width="0dp"
        android:layout_height="@dimen/btn_height"
        android:text="ĐĂNG XUẤT"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:background="@drawable/bg_button_primary"
        android:layout_marginTop="@dimen/spacing_xl"
        app:layout_constraintTop_toBottomOf="@id/card_role"
        app:layout_constraintStart_toEndOf="@id/gl_start"
        app:layout_constraintEnd_toStartOf="@id/gl_end" />

</androidx.constraintlayout.widget.ConstraintLayout>
