<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_forgot_otp.xml — Forgot Password step 2: OTP verification.
    Reuses the same 6-box OTP design from the registration flow.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_surface"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_xl">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_primary"
            android:contentDescription="Quay lại"
            android:layout_marginTop="@dimen/spacing_xl"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/screen_title_otp"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_xxl"
            android:textStyle="bold"
            android:layout_marginTop="@dimen/spacing_xl"
            app:layout_constraintTop_toBottomOf="@id/btn_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Description -->
        <TextView
            android:id="@+id/tv_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/forgot_otp_description"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_sm"
            android:layout_marginTop="@dimen/spacing_sm"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Email display -->
        <TextView
            android:id="@+id/tv_email"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/color_primary"
            android:textSize="@dimen/text_md"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tv_description"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 6 OTP boxes -->
        <LinearLayout
            android:id="@+id/ll_otp_boxes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="@dimen/spacing_xl"
            app:layout_constraintTop_toBottomOf="@id/tv_email"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText android:id="@+id/et_otp1"
                android:layout_width="44dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_otp_box"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:layout_marginHorizontal="4dp" />
            <EditText android:id="@+id/et_otp2"
                android:layout_width="44dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_otp_box"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:layout_marginHorizontal="4dp" />
            <EditText android:id="@+id/et_otp3"
                android:layout_width="44dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_otp_box"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:layout_marginHorizontal="4dp" />
            <EditText android:id="@+id/et_otp4"
                android:layout_width="44dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_otp_box"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:layout_marginHorizontal="4dp" />
            <EditText android:id="@+id/et_otp5"
                android:layout_width="44dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_otp_box"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:layout_marginHorizontal="4dp" />
            <EditText android:id="@+id/et_otp6"
                android:layout_width="44dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_otp_box"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:layout_marginHorizontal="4dp" />
        </LinearLayout>

        <!-- Resend OTP link -->
        <TextView
            android:id="@+id/tv_resend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/otp_resend_countdown"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_sm"
            android:layout_marginTop="@dimen/spacing_lg"
            app:layout_constraintTop_toBottomOf="@id/ll_otp_boxes"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Verify button -->
        <Button
            android:id="@+id/btn_verify"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height"
            android:text="@string/btn_verify_otp"
            style="@style/Widget.AidBridge.Button.Primary"
            android:layout_marginTop="@dimen/spacing_xl"
            app:layout_constraintTop_toBottomOf="@id/tv_resend"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ProgressBar -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminateTint="@color/color_primary"
            android:layout_marginTop="@dimen/spacing_md"
            app:layout_constraintTop_toBottomOf="@id/btn_verify"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
