<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_otp.xml — OTP verification screen.

    Design:
    - Dark bg_surface background
    - Title "Xác thực OTP" + description showing masked email
    - 6 individual EditText boxes (auto-advance on each keystroke)
    - "XÁC NHẬN →" blue primary button
    - "Chưa nhận được mã? Gửi lại (Xs)" countdown resend link
    - Kết quả xác thực OTP phụ thuộc phản hồi API từ backend
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_surface"
    android:paddingHorizontal="@dimen/spacing_lg">

    <!-- Back button -->
    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_media_previous"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/text_primary"
        android:contentDescription="Back"
        android:layout_marginTop="@dimen/spacing_xl"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Title: "Xác thực OTP" -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/otp_title"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_xxl"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="@dimen/spacing_xxl"
        app:layout_constraintTop_toBottomOf="@+id/btn_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Description: "Mã OTP đã được gửi đến {email}" -->
    <TextView
        android:id="@+id/tv_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/otp_description"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_md"
        android:gravity="center"
        android:layout_marginTop="@dimen/spacing_sm"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Email label (set dynamically) -->
    <TextView
        android:id="@+id/tv_email"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/color_primary"
        android:textSize="@dimen/text_md"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_description"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 6 OTP boxes in a horizontal LinearLayout -->
    <LinearLayout
        android:id="@+id/ll_otp_boxes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="@dimen/spacing_xl"
        app:layout_constraintTop_toBottomOf="@+id/tv_email"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/et_otp_1"
            android:layout_width="@dimen/otp_box_size"
            android:layout_height="@dimen/otp_box_size"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_otp_box"
            android:inputType="number"
            android:maxLength="1"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold"
            android:cursorVisible="false" />

        <EditText
            android:id="@+id/et_otp_2"
            android:layout_width="@dimen/otp_box_size"
            android:layout_height="@dimen/otp_box_size"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_otp_box"
            android:inputType="number"
            android:maxLength="1"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold"
            android:cursorVisible="false" />

        <EditText
            android:id="@+id/et_otp_3"
            android:layout_width="@dimen/otp_box_size"
            android:layout_height="@dimen/otp_box_size"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_otp_box"
            android:inputType="number"
            android:maxLength="1"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold"
            android:cursorVisible="false" />

        <EditText
            android:id="@+id/et_otp_4"
            android:layout_width="@dimen/otp_box_size"
            android:layout_height="@dimen/otp_box_size"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_otp_box"
            android:inputType="number"
            android:maxLength="1"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold"
            android:cursorVisible="false" />

        <EditText
            android:id="@+id/et_otp_5"
            android:layout_width="@dimen/otp_box_size"
            android:layout_height="@dimen/otp_box_size"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_otp_box"
            android:inputType="number"
            android:maxLength="1"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold"
            android:cursorVisible="false" />

        <EditText
            android:id="@+id/et_otp_6"
            android:layout_width="@dimen/otp_box_size"
            android:layout_height="@dimen/otp_box_size"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_otp_box"
            android:inputType="number"
            android:maxLength="1"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold"
            android:cursorVisible="false" />
    </LinearLayout>

    <!-- "XÁC NHẬN →" button -->
    <Button
        android:id="@+id/btn_verify"
        android:layout_width="0dp"
        android:layout_height="@dimen/btn_height"
        android:text="@string/btn_verify_otp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:background="@drawable/bg_button_primary"
        android:layout_marginTop="@dimen/spacing_xl"
        app:layout_constraintTop_toBottomOf="@+id/ll_otp_boxes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Loading ProgressBar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@color/color_primary"
        android:layout_marginTop="@dimen/spacing_sm"
        app:layout_constraintTop_toBottomOf="@+id/btn_verify"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Resend / countdown text -->
    <TextView
        android:id="@+id/tv_resend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/otp_resend_countdown"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_sm"
        android:gravity="center"
        android:layout_marginTop="@dimen/spacing_md"
        app:layout_constraintTop_toBottomOf="@+id/progress_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
