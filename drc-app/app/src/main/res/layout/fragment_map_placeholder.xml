<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_map_placeholder.xml — Phase 2 placeholder for the Map tab.

    Will be replaced by actual Google Maps integration in Phase 3.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <ImageView
        android:id="@+id/iv_map_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_map"
        android:alpha="0.4"
        android:contentDescription="Map placeholder"
        app:tint="@color/color_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tv_placeholder_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_placeholder_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/map_placeholder_title"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_xl"
        android:textStyle="bold"
        android:layout_marginTop="@dimen/spacing_md"
        app:layout_constraintTop_toBottomOf="@+id/iv_map_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_placeholder_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/map_placeholder_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_md"
        android:gravity="center"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginHorizontal="@dimen/spacing_xl"
        app:layout_constraintTop_toBottomOf="@+id/tv_placeholder_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
