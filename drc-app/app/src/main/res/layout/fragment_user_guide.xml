<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_user_guide.xml — User Guide screen layout.
    Provides information about SOS features, map, registration, and user roles.
    Content derived from requirements.md (AidBridge DRC project).
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Collapsing toolbar with title -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_surface"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="56dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_primary"
                android:contentDescription="Quay lại"
                android:layout_marginStart="@dimen/spacing_md"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/guide_title"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/btn_back"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_default" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable guide content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingTop="@dimen/spacing_lg"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- SECTION 1: SOS Khẩn cấp -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/guide_section_sos_title"
                android:textColor="@color/sos_red"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_default"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guide_sos_step1"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md"
                        android:drawableStart="@drawable/ic_sos_nav"
                        android:drawableTint="@color/sos_red"
                        android:drawablePadding="@dimen/spacing_sm"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guide_sos_step2"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guide_sos_step3"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guide_sos_note"
                        android:textColor="@color/safe_green"
                        android:textSize="@dimen/text_sm"
                        android:textStyle="italic" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 2: Bản đồ cứu trợ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/guide_section_map_title"
                android:textColor="@color/hub_blue"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_default"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guide_map_hub"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guide_map_shelter"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guide_map_safe_path"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guide_map_heatmap"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 3: Đăng ký / Đăng nhập -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/guide_section_auth_title"
                android:textColor="@color/color_primary"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_default"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guide_auth_register"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guide_auth_otp"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guide_auth_login"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 4: Vai trò người dùng -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/guide_section_roles_title"
                android:textColor="@color/safe_green"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_default"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guide_role_victim"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guide_role_volunteer"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guide_role_sponsor"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
