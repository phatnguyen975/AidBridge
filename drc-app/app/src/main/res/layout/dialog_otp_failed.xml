<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_otp_failed.xml — shown when user enters wrong OTP code.

    Design: rounded dark dialog, red circle + X icon, fail title + message, "THỬ LẠI" button.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:paddingHorizontal="@dimen/spacing_xl"
    android:paddingVertical="@dimen/spacing_xl">

    <!-- Red circle icon -->
    <FrameLayout
        android:id="@+id/frame_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_icon_error"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_close"
            android:contentDescription="Failed" />
    </FrameLayout>

    <!-- "Mã OTP không đúng" -->
    <TextView
        android:id="@+id/tv_failed_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/otp_failed_title"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_xl"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="@dimen/spacing_lg"
        app:layout_constraintTop_toBottomOf="@+id/frame_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tv_failed_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/otp_failed_message"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_md"
        android:gravity="center"
        android:layout_marginTop="@dimen/spacing_sm"
        app:layout_constraintTop_toBottomOf="@+id/tv_failed_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- "THỬ LẠI" button -->
    <Button
        android:id="@+id/btn_retry"
        android:layout_width="0dp"
        android:layout_height="@dimen/btn_height"
        android:text="@string/btn_retry"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:background="@drawable/bg_button_primary"
        android:layout_marginTop="@dimen/spacing_xl"
        app:layout_constraintTop_toBottomOf="@+id/tv_failed_message"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
