<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph_staff"
    app:startDestination="@id/staffProfileFragment">

    <fragment
        android:id="@+id/staffProfileFragment"
        android:name="com.drc.aidbridge.ui.main.fragment.staff.StaffProfileFragment"
        android:label="StaffProfileFragment" />

    <fragment
        android:id="@+id/staffInventoryFragment"
        android:name="com.drc.aidbridge.ui.main.fragment.staff.StaffInventoryFragment"
        android:label="StaffInventoryFragment">

        <action
            android:id="@+id/action_staffInventoryFragment_to_staffScannerFragment"
            app:destination="@id/staffScannerFragment" />
    </fragment>

    <fragment
        android:id="@+id/staffTasksFragment"
        android:name="com.drc.aidbridge.ui.main.fragment.staff.StaffTasksFragment"
        android:label="StaffTasksFragment" />

    <fragment
        android:id="@+id/staffMapFragment"
        android:name="com.drc.aidbridge.ui.map.fragment.StaffMapFragment"
        android:label="StaffMapFragment" />

    <fragment
        android:id="@+id/staffScannerFragment"
        android:name="com.drc.aidbridge.ui.main.fragment.staff.StaffScannerFragment"
        android:label="StaffScannerFragment">

        <action
            android:id="@+id/action_staffScannerFragment_to_staffImportDetailFragment"
            app:destination="@id/staffImportDetailFragment" />

        <action
            android:id="@+id/action_staffScannerFragment_to_staffExportDetailFragment"
            app:destination="@id/staffExportDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/staffImportDetailFragment"
        android:name="com.drc.aidbridge.ui.main.fragment.staff.StaffImportDetailFragment"
        android:label="StaffImportDetailFragment" />

    <fragment
        android:id="@+id/staffExportDetailFragment"
        android:name="com.drc.aidbridge.ui.main.fragment.staff.StaffExportDetailFragment"
        android:label="StaffExportDetailFragment" />
</navigation>
