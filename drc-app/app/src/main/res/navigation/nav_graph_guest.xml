<?xml version="1.0" encoding="utf-8"?>
<!--
    nav_graph_guest.xml — Navigation graph for the guest/authentication flow.

    Flow:
      GuestShellFragment (start)
          ├─ action_guestShellFragment_to_loginFragment    → LoginFragment
          └─ action_guestShellFragment_to_registerFragment → RegisterFragment

      LoginFragment
          └─ action_loginFragment_to_registerFragment → RegisterFragment

      RegisterFragment
          └─ action_registerFragment_to_otpFragment  → OtpFragment

    OtpFragment navigates to MainActivity programmatically (startActivity),
    so no action from OtpFragment is defined here.
-->
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph_guest"
    app:startDestination="@id/guestShellFragment">

    <!-- ============================================================
         Guest shell (rescue + map tabs)
         ============================================================ -->
    <fragment
        android:id="@+id/guestShellFragment"
        android:name="com.drc.aidbridge.ui.auth.fragment.GuestShellFragment"
        android:label="GuestShellFragment">

        <!-- → Login -->
        <action
            android:id="@+id/action_guestShellFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <!-- → Register -->
        <action
            android:id="@+id/action_guestShellFragment_to_registerFragment"
            app:destination="@id/registerFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <!-- → User guide -->
        <action
            android:id="@+id/action_guestShellFragment_to_userGuideFragment"
            app:destination="@id/userGuideFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- ============================================================
         User guide screen
         ============================================================ -->
    <fragment
        android:id="@+id/userGuideFragment"
        android:name="com.drc.aidbridge.ui.auth.fragment.UserGuideFragment"
        android:label="UserGuideFragment" />

    <!-- ============================================================
         Login screen
         ============================================================ -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.drc.aidbridge.ui.auth.fragment.LoginFragment"
        android:label="LoginFragment">

        <!-- → Register (from "Đăng ký tài khoản mới" link) -->
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <!-- → Forgot Password flow -->
        <action
            android:id="@+id/action_loginFragment_to_forgotEmailFragment"
            app:destination="@id/forgotEmailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <!-- → MainActivity sau khi đăng nhập thành công.
             popUpTo nav_graph_guest + popUpToInclusive=true → xóa sạch toàn bộ
             Fragment back stack (Guest, Login) để người dùng không thể Back về màn đăng nhập. -->
        <action
            android:id="@+id/action_loginFragment_to_mainActivity"
            app:destination="@id/mainActivity"
            app:popUpTo="@id/nav_graph_guest"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- ============================================================
         Register screen
         ============================================================ -->
    <fragment
        android:id="@+id/registerFragment"
        android:name="com.drc.aidbridge.ui.auth.fragment.RegisterFragment"
        android:label="RegisterFragment">

        <!-- → Login (from "Đăng nhập" link in register screen) -->
        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:enterAnim="@anim/slide_in_left"
            app:exitAnim="@anim/slide_out_right"
            app:popEnterAnim="@anim/slide_in_right"
            app:popExitAnim="@anim/slide_out_left"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />

        <!-- → OTP (sau khi đăng ký thành công) -->
        <action
            android:id="@+id/action_registerFragment_to_otpFragment"
            app:destination="@id/otpFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- ============================================================
         OTP verification screen
         ============================================================ -->
    <fragment
        android:id="@+id/otpFragment"
        android:name="com.drc.aidbridge.ui.auth.fragment.OtpFragment"
        android:label="OtpFragment">

        <!-- Receives the email string argument from RegisterFragment -->
        <argument
            android:name="email"
            app:argType="string"
            android:defaultValue="" />

        <!-- → Login after successful OTP verification in register flow. -->
        <action
            android:id="@+id/action_otpFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true"
            app:launchSingleTop="true" />
    </fragment>

    <!-- ============================================================
         Forgot Password flow
         ============================================================ -->

    <!-- Step 1: Enter email address -->
    <fragment
        android:id="@+id/forgotEmailFragment"
        android:name="com.drc.aidbridge.ui.auth.fragment.ForgotEmailFragment"
        android:label="ForgotEmailFragment">

        <!-- → Step 2: Enter OTP -->
        <action
            android:id="@+id/action_forgotEmailFragment_to_forgotOtpFragment"
            app:destination="@id/forgotOtpFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- Step 2: OTP verification -->
    <fragment
        android:id="@+id/forgotOtpFragment"
        android:name="com.drc.aidbridge.ui.auth.fragment.ForgotOtpFragment"
        android:label="ForgotOtpFragment">

        <!-- Email passed from ForgotEmailFragment -->
        <argument
            android:name="email"
            app:argType="string"
            android:defaultValue="" />

        <!-- → Step 3: Set new password -->
        <action
            android:id="@+id/action_forgotOtpFragment_to_forgotNewPasswordFragment"
            app:destination="@id/forgotNewPasswordFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- Step 3: Set new password -->
    <fragment
        android:id="@+id/forgotNewPasswordFragment"
        android:name="com.drc.aidbridge.ui.auth.fragment.ForgotNewPasswordFragment"
        android:label="ForgotNewPasswordFragment">

        <!-- Email passed from ForgotOtpFragment -->
        <argument
            android:name="email"
            app:argType="string"
            android:defaultValue="" />
        
        <action
            android:id="@+id/action_forgotNewPasswordFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- ============================================================
         MainActivity — đích đến sau khi đăng nhập thành công.
         Được khai báo như <activity> destination để dùng popUpTo
         xóa sạch toàn bộ Fragment back stack của luồng Auth.
         ============================================================ -->
    <activity
        android:id="@+id/mainActivity"
        android:name="com.drc.aidbridge.ui.main.MainActivity"
        android:label="MainActivity" />

</navigation>
