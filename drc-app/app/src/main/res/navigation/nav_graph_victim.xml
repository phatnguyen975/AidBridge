<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph_victim"
    app:startDestination="@id/victimProfileFragment">

    <fragment
        android:id="@+id/victimProfileFragment"
        android:name="com.drc.aidbridge.ui.main.fragment.victim.VictimProfileFragment"
        android:label="VictimProfileFragment">

        <action
            android:id="@+id/action_profile_to_map"
            app:destination="@id/victimMapFragment" />

        <action
            android:id="@+id/action_profile_to_history"
            app:destination="@id/victimHistoryFragment" />

        <action
            android:id="@+id/action_profile_to_personalInfo"
            app:destination="@id/victimPersonalInfoFragment" />
    </fragment>

    <fragment
        android:id="@+id/victimMapFragment"
        android:name="com.drc.aidbridge.ui.map.fragment.VictimMapFragment"
        android:label="VictimMapFragment">

        <action
            android:id="@+id/action_map_to_profile"
            app:destination="@id/victimProfileFragment" />
    </fragment>

    <fragment
        android:id="@+id/victimHistoryFragment"
        android:name="com.drc.aidbridge.ui.main.fragment.victim.VictimHistoryFragment"
        android:label="VictimHistoryFragment" />

    <fragment
        android:id="@+id/victimSosSelfFragment"
        android:name="com.drc.aidbridge.ui.main.fragment.victim.VictimSosSelfFragment"
        android:label="VictimSosSelfFragment" />

    <fragment
        android:id="@+id/victimSosRelativeFragment"
        android:name="com.drc.aidbridge.ui.main.fragment.victim.VictimSosRelativeFragment"
        android:label="VictimSosRelativeFragment" />

    <fragment
        android:id="@+id/victimPersonalInfoFragment"
        android:name="com.drc.aidbridge.ui.main.fragment.victim.VictimPersonalInfoFragment"
        android:label="VictimPersonalInfoFragment" />
</navigation>
