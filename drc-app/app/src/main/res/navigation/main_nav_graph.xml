<?xml version="1.0" encoding="utf-8"?>
<!--
    main_nav_graph.xml — Navigation graph cho shell sau khi đăng nhập (MainActivity).

    Phase 2:
      homeFragment (start) → Trang chủ: thông tin người dùng + vai trò + đăng xuất.
      mapFragment           → Placeholder bản đồ (Phase 3: Google Maps thật).

    Phase 3: Bổ sung các Fragment theo từng role (SosFragment, DashboardFragment,...).
-->
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- Trang chủ: hiển thị thông tin người dùng và nút đăng xuất -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.drc.aidbridge.ui.main.HomeFragment"
        android:label="HomeFragment" />

    <!-- Bản đồ (Phase 3: tích hợp Google Maps thật) -->
    <fragment
        android:id="@+id/mapFragment"
        android:name="com.drc.aidbridge.ui.main.MapFragment"
        android:label="MapFragment" />

</navigation>
