<?xml version="1.0" encoding="utf-8"?>
<!-- Role card border selector: highlighted when selected -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#1A288DFA" />
            <stroke android:width="2dp" android:color="@color/color_primary" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@color/bg_card" />
            <stroke android:width="1dp" android:color="@color/border_default" />
        </shape>
    </item>
</selector>
