    <!-- User Guide Screen -->
    <string name="guide_title">HƯỚNG DẪN SỬ DỤNG</string>
    <string name="guide_back_icon">Quay lại</string>
    <string name="guide_section_sos_title">1. Gửi SOS Khẩn cấp</string>
    <string name="guide_sos_step1">Mở ứng dụng » Màn hình hiển thị nút SOS.</string>
