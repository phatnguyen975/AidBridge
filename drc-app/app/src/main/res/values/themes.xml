<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- === Base Application Theme (forced dark) === -->
    <style name="Base.Theme.AidBridge" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color used for buttons, links, highlights -->
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryVariant">@color/color_primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- App dark background -->
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Secondary accent -->
        <item name="colorSecondary">@color/color_primary</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- TextInputLayout styling (outlined inputs) -->
        <item name="textInputStyle">@style/Widget.AidBridge.TextInputLayout</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
    </style>

    <style name="Theme.AidBridge" parent="Base.Theme.AidBridge" />

    <!-- Also keep legacy name for compatibility (existing build.gradle references) -->
    <style name="Theme.DRCApp" parent="Theme.AidBridge" />

    <!-- === TextInputLayout custom style === -->
    <style name="Widget.AidBridge.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_input</item>
        <item name="boxStrokeColor">@color/border_input</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- === Splash Screen style === -->
    <style name="Theme.AidBridge.Splash" parent="Theme.AidBridge">
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- === Button styles === -->
    <!-- Primary action button (blue fill) -->
    <style name="Widget.AidBridge.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/color_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Ghost/outline button (dark with border) -->
    <style name="Widget.AidBridge.Button.Ghost" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/border_default</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/bg_surface_elevated</item>
    </style>

    <!-- OTP confirm button -->
    <style name="Widget.AidBridge.Button.OtpConfirm" parent="Widget.AidBridge.Button.Primary">
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- === OTP digit box === -->
    <style name="Widget.AidBridge.OtpBox" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:inputType">number</item>
        <item name="android:maxLength">1</item>
        <item name="android:background">@drawable/bg_otp_box</item>
        <item name="android:padding">0dp</item>
    </style>

    <!-- === Role selection card style === -->
    <style name="Widget.AidBridge.RoleCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="strokeColor">@color/border_default</item>
        <item name="cardCornerRadius">12dp</item>
    </style>

    <!-- === Dialog theme === -->
    <style name="Theme.AidBridge.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="android:windowBackground">@drawable/bg_dialog_rounded</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>
</resources>
