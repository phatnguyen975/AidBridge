<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/sponsor_profile_toolbar_height"
        android:paddingStart="@dimen/sponsor_profile_content_padding"
        android:paddingEnd="@dimen/sponsor_profile_content_padding">

        <ImageView
            android:id="@+id/iv_profile_logo"
            android:layout_width="@dimen/sponsor_dashboard_logo_size"
            android:layout_height="@dimen/sponsor_dashboard_logo_size"
            android:contentDescription="@string/app_logo"
            android:src="@mipmap/ic_launcher"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_profile_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sponsor_profile_title"
            android:textAllCaps="true"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/sponsor_profile_toolbar_title_text_size"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="@dimen/sponsor_profile_divider_thickness"
        app:dividerColor="@color/border_default"
        app:dividerThickness="@dimen/sponsor_profile_divider_thickness" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/sponsor_profile_content_padding">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_surface_elevated"
                app:cardCornerRadius="@dimen/sponsor_profile_card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_default"
                app:strokeWidth="@dimen/sponsor_hub_item_stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="@dimen/sponsor_profile_card_padding">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layout_avatar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_avatar"
                            android:layout_width="@dimen/sponsor_profile_avatar_size"
                            android:layout_height="@dimen/sponsor_profile_avatar_size"
                            android:contentDescription="@string/sponsor_profile_avatar_desc"
                            android:padding="@dimen/sponsor_profile_avatar_inner_padding"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_avatar"
                            app:shapeAppearanceOverlay="@style/CircleAppearance"
                            app:strokeColor="@color/color_primary"
                            app:strokeWidth="@dimen/sponsor_profile_avatar_stroke"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/card_edit_avatar"
                            android:layout_width="@dimen/sponsor_profile_avatar_edit_size"
                            android:layout_height="@dimen/sponsor_profile_avatar_edit_size"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            app:cardBackgroundColor="@color/color_primary"
                            app:cardCornerRadius="@dimen/sponsor_profile_avatar_edit_size"
                            app:cardElevation="0dp"
                            app:layout_constraintBottom_toBottomOf="@id/iv_avatar"
                            app:layout_constraintEnd_toEndOf="@id/iv_avatar">

                            <ImageView
                                android:layout_width="@dimen/sponsor_profile_avatar_edit_icon_size"
                                android:layout_height="@dimen/sponsor_profile_avatar_edit_icon_size"
                                android:layout_gravity="center"
                                android:contentDescription="@string/sponsor_profile_edit_avatar_desc"
                                android:src="@drawable/ic_pencil"
                                app:tint="@color/text_primary" />
                        </com.google.android.material.card.MaterialCardView>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <TextView
                        android:id="@+id/tv_sponsor_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sponsor_profile_name_margin_top"
                        android:text="@string/sponsor_profile_mock_name"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/sponsor_profile_name_text_size"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_sponsor_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sponsor_profile_badge_margin_top"
                        android:clickable="false"
                        android:focusable="false"
                        android:text="@string/sponsor_profile_premium_badge"
                        android:gravity="center_vertical"
                        android:textColor="@color/sponsor_profile_badge_border"
                        android:textSize="@dimen/sponsor_profile_badge_text_size"
                        android:textStyle="bold"
                        app:chipBackgroundColor="@color/sponsor_profile_badge_bg"
                        app:chipIcon="@android:drawable/btn_star_big_on"
                        app:chipIconSize="@dimen/sponsor_profile_badge_icon_size"
                        app:chipIconTint="@color/sponsor_profile_badge_border"
                        app:chipStrokeColor="@color/sponsor_profile_badge_border"
                        app:chipStrokeWidth="@dimen/sponsor_profile_badge_stroke_width"
                        app:ensureMinTouchTargetSize="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sponsor_profile_card_margin_top"
                app:cardBackgroundColor="@color/bg_surface_elevated"
                app:cardCornerRadius="@dimen/sponsor_profile_card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_default"
                app:strokeWidth="@dimen/sponsor_hub_item_stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/row_edit_profile"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/sponsor_profile_menu_row_height"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/sponsor_profile_card_padding"
                        android:paddingEnd="@dimen/sponsor_profile_card_padding">

                        <ImageView
                            android:layout_width="@dimen/sponsor_profile_menu_icon_size"
                            android:layout_height="@dimen/sponsor_profile_menu_icon_size"
                            android:contentDescription="@string/sponsor_profile_edit_info"
                            android:src="@drawable/ic_person"
                            app:tint="@color/text_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/sponsor_profile_menu_icon_gap"
                            android:layout_weight="1"
                            android:text="@string/sponsor_profile_edit_info"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/sponsor_profile_menu_text_size" />

                        <ImageView
                            android:layout_width="@dimen/sponsor_profile_menu_icon_size"
                            android:layout_height="@dimen/sponsor_profile_menu_icon_size"
                            android:contentDescription="@string/sponsor_profile_edit_info"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_secondary" />
                    </LinearLayout>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/sponsor_profile_divider_thickness"
                        app:dividerColor="@color/border_default" />

                    <LinearLayout
                        android:id="@+id/row_change_password"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/sponsor_profile_menu_row_height"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/sponsor_profile_card_padding"
                        android:paddingEnd="@dimen/sponsor_profile_card_padding">

                        <ImageView
                            android:layout_width="@dimen/sponsor_profile_menu_icon_size"
                            android:layout_height="@dimen/sponsor_profile_menu_icon_size"
                            android:contentDescription="@string/sponsor_profile_change_password"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/text_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/sponsor_profile_menu_icon_gap"
                            android:layout_weight="1"
                            android:text="@string/sponsor_profile_change_password"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/sponsor_profile_menu_text_size" />

                        <ImageView
                            android:layout_width="@dimen/sponsor_profile_menu_icon_size"
                            android:layout_height="@dimen/sponsor_profile_menu_icon_size"
                            android:contentDescription="@string/sponsor_profile_change_password"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_secondary" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sponsor_profile_card_margin_top"
                app:cardBackgroundColor="@color/bg_surface_elevated"
                app:cardCornerRadius="@dimen/sponsor_profile_card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_default"
                app:strokeWidth="@dimen/sponsor_hub_item_stroke_width">

                <LinearLayout
                    android:id="@+id/row_donation_history"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/sponsor_profile_menu_row_height"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/sponsor_profile_card_padding"
                    android:paddingEnd="@dimen/sponsor_profile_card_padding">

                    <ImageView
                        android:layout_width="@dimen/sponsor_profile_menu_icon_size"
                        android:layout_height="@dimen/sponsor_profile_menu_icon_size"
                        android:contentDescription="@string/sponsor_profile_history"
                        android:src="@drawable/ic_history"
                        app:tint="@color/text_primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sponsor_profile_menu_icon_gap"
                        android:layout_weight="1"
                        android:text="@string/sponsor_profile_history"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/sponsor_profile_menu_text_size" />

                    <ImageView
                        android:layout_width="@dimen/sponsor_profile_menu_icon_size"
                        android:layout_height="@dimen/sponsor_profile_menu_icon_size"
                        android:contentDescription="@string/sponsor_profile_history"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/spacing_md"
                android:layout_marginTop="@dimen/sponsor_profile_logout_margin_top"
                android:backgroundTint="@android:color/transparent"
                android:text="@string/sponsor_profile_logout"
                android:textAllCaps="false"
                android:textColor="@color/sos_red"
                app:cornerRadius="@dimen/sponsor_profile_button_radius"
                app:icon="@drawable/ic_logout"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/sponsor_profile_menu_icon_gap"
                app:iconTint="@color/sos_red"
                app:strokeColor="@color/sos_red"
                app:strokeWidth="@dimen/sponsor_hub_item_stroke_width" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
