<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_surface"
    android:orientation="vertical"
    android:padding="@dimen/staff_tasks_screen_padding">

    <View
        android:layout_width="@dimen/staff_task_sheet_handle_width"
        android:layout_height="@dimen/staff_task_sheet_handle_height"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_staff_sheet_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/staff_task_sheet_header_margin_top"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/staff_task_sheet_title_text_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_staff_detail_status_chip"
            android:paddingStart="@dimen/staff_task_item_chip_padding_h"
            android:paddingTop="@dimen/staff_task_item_chip_padding_v"
            android:paddingEnd="@dimen/staff_task_item_chip_padding_h"
            android:paddingBottom="@dimen/staff_task_item_chip_padding_v"
            android:textColor="@color/color_primary"
            android:textSize="@dimen/staff_task_item_status_chip_text_size"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/staff_task_sheet_person_margin_top"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/staff_detail_row_icon_size"
                android:layout_height="@dimen/staff_detail_row_icon_size"
                android:contentDescription="@string/staff_detail_role_volunteer"
                android:src="@drawable/ic_person"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tv_person_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/staff_task_item_person_gap"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/staff_task_item_person_size"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/staff_task_sheet_phone_margin_top"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/staff_detail_row_icon_size"
                android:layout_height="@dimen/staff_detail_row_icon_size"
                android:contentDescription="@string/staff_profile_phone_label"
                android:src="@drawable/ic_phone"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tv_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/staff_task_item_person_gap"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/staff_task_item_person_size" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="@dimen/staff_profile_divider_thickness"
        android:layout_marginTop="@dimen/staff_task_sheet_section_margin_top"
        app:dividerColor="@color/border_default"
        app:dividerThickness="@dimen/staff_profile_divider_thickness" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/staff_task_sheet_section_margin_top"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:text="@string/staff_task_expected_items"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/staff_task_sheet_expected_title_size"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/ll_expected_items_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_close"
        style="@style/Widget.AidBridge.Button.Ghost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/staff_task_sheet_close_margin_top"
        android:paddingVertical="@dimen/spacing_md"
        android:text="@string/staff_task_detail_btn_close" />

</LinearLayout>
