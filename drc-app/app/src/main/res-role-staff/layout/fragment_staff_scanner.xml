<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_toolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/staff_profile_toolbar_height"
        android:paddingStart="@dimen/staff_profile_screen_padding"
        android:paddingEnd="@dimen/staff_profile_screen_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="@dimen/staff_scanner_back_icon_size"
            android:layout_height="@dimen/staff_scanner_back_icon_size"
            android:contentDescription="@string/btn_back"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_primary" />

        <TextView
            android:id="@+id/tv_toolbar_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/staff_profile_toolbar_title_text_size"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.divider.MaterialDivider
        android:id="@+id/divider_toolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/staff_profile_divider_thickness"
        app:dividerColor="@color/border_default"
        app:dividerThickness="@dimen/staff_profile_divider_thickness"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_toolbar" />

    <View
        android:id="@+id/view_scan_outer_frame"
        android:layout_width="@dimen/staff_scanner_outer_frame_size"
        android:layout_height="@dimen/staff_scanner_outer_frame_size"
        android:layout_marginTop="@dimen/staff_scanner_frame_top_margin"
        android:background="@drawable/bg_staff_scanner_outer_frame"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider_toolbar" />

    <View
        android:id="@+id/view_scan_area"
        android:layout_width="@dimen/staff_scanner_inner_frame_size"
        android:layout_height="@dimen/staff_scanner_inner_frame_size"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="@id/view_scan_outer_frame"
        app:layout_constraintEnd_toEndOf="@id/view_scan_outer_frame"
        app:layout_constraintStart_toStartOf="@id/view_scan_outer_frame"
        app:layout_constraintTop_toTopOf="@id/view_scan_outer_frame" />

    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@id/view_scan_area"
        app:layout_constraintEnd_toEndOf="@id/view_scan_area"
        app:layout_constraintStart_toStartOf="@id/view_scan_area"
        app:layout_constraintTop_toTopOf="@id/view_scan_area" />

    <ImageView
        android:id="@+id/iv_corner_top_left"
        android:layout_width="@dimen/staff_scanner_corner_size"
        android:layout_height="@dimen/staff_scanner_corner_size"
        android:src="@drawable/ic_staff_scanner_bracket"
        app:layout_constraintStart_toStartOf="@id/view_scan_area"
        app:layout_constraintTop_toTopOf="@id/view_scan_area" />

    <ImageView
        android:id="@+id/iv_corner_top_right"
        android:layout_width="@dimen/staff_scanner_corner_size"
        android:layout_height="@dimen/staff_scanner_corner_size"
        android:rotation="90"
        android:src="@drawable/ic_staff_scanner_bracket"
        app:layout_constraintEnd_toEndOf="@id/view_scan_area"
        app:layout_constraintTop_toTopOf="@id/view_scan_area" />

    <ImageView
        android:id="@+id/iv_corner_bottom_left"
        android:layout_width="@dimen/staff_scanner_corner_size"
        android:layout_height="@dimen/staff_scanner_corner_size"
        android:rotation="-90"
        android:src="@drawable/ic_staff_scanner_bracket"
        app:layout_constraintBottom_toBottomOf="@id/view_scan_area"
        app:layout_constraintStart_toStartOf="@id/view_scan_area" />

    <ImageView
        android:id="@+id/iv_corner_bottom_right"
        android:layout_width="@dimen/staff_scanner_corner_size"
        android:layout_height="@dimen/staff_scanner_corner_size"
        android:rotation="180"
        android:src="@drawable/ic_staff_scanner_bracket"
        app:layout_constraintBottom_toBottomOf="@id/view_scan_area"
        app:layout_constraintEnd_toEndOf="@id/view_scan_area" />

    <TextView
        android:id="@+id/tv_instruction"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/staff_profile_screen_padding"
        android:layout_marginEnd="@dimen/staff_profile_screen_padding"
        android:layout_marginTop="@dimen/spacing_lg"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_md"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_scan_outer_frame" />

    <TextView
        android:id="@+id/tv_subtext"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/staff_profile_screen_padding"
        android:layout_marginEnd="@dimen/staff_profile_screen_padding"
        android:layout_marginTop="@dimen/spacing_sm"
        android:gravity="center"
        android:text="@string/staff_scan_subtext"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_sm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_instruction" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_manual_entry"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/staff_profile_screen_padding"
        android:layout_marginEnd="@dimen/staff_profile_screen_padding"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:backgroundTint="@android:color/transparent"
        android:text="@string/staff_scan_manual_btn"
        android:textAllCaps="false"
        android:paddingVertical="@dimen/spacing_md"
        android:textColor="@color/color_primary"
        app:icon="@drawable/ic_keyboard"
        app:iconGravity="textStart"
        app:iconPadding="@dimen/spacing_sm"
        app:iconTint="@color/color_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="@color/color_primary"
        app:strokeWidth="1dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
