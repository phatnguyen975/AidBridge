<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.AidBridge.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/staff_task_item_margin_bottom"
    app:cardBackgroundColor="@color/bg_surface_elevated">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/staff_task_item_padding">

        <TextView
            android:id="@+id/tv_task_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/staff_task_item_code_text_size"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/staff_task_item_bottom_margin_top"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/staff_task_item_icon_size"
                android:layout_height="@dimen/staff_task_item_icon_size"
                android:contentDescription="@string/staff_detail_role_volunteer"
                android:src="@drawable/ic_person"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tv_person_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/staff_task_item_person_gap"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/staff_task_item_person_size" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/staff_task_item_bottom_margin_top"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/staff_task_item_icon_size"
                android:layout_height="@dimen/staff_task_item_icon_size"
                android:contentDescription="@string/staff_inventory_updated_ago"
                android:src="@drawable/ic_phone"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tv_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/staff_task_item_person_gap"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/staff_task_item_person_size" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
