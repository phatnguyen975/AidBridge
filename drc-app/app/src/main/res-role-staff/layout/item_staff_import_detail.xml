<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.AidBridge.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/staff_detail_item_margin_bottom"
    app:cardBackgroundColor="@color/bg_surface_elevated">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/staff_inventory_item_content_padding">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="@dimen/staff_detail_item_image_size"
            android:layout_height="@dimen/staff_detail_item_image_size"
            app:cardCornerRadius="@dimen/radius_sm"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/iv_product"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/app_logo"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_launcher" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/staff_detail_row_gap"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/staff_detail_item_name_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_donation_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/staff_detail_item_meta_size" />

            <TextView
                android:id="@+id/tv_error_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:background="@drawable/bg_staff_detail_error_badge"
                android:paddingStart="@dimen/staff_detail_error_badge_padding_h"
                android:paddingTop="@dimen/staff_detail_error_badge_padding_v"
                android:paddingEnd="@dimen/staff_detail_error_badge_padding_h"
                android:paddingBottom="@dimen/staff_detail_error_badge_padding_v"
                android:text="@string/staff_detail_insufficient"
                android:textColor="@color/sos_red"
                android:textSize="@dimen/staff_detail_item_badge_size"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <EditText
            android:id="@+id/et_quantity"
            android:layout_width="72dp"
            android:layout_height="48dp"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:background="@drawable/bg_staff_detail_status_chip"
            android:gravity="center"
            android:inputType="number"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/staff_detail_item_meta_size"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/iv_status"
            android:layout_width="@dimen/staff_detail_status_icon_size"
            android:layout_height="@dimen/staff_detail_status_icon_size"
            android:contentDescription="@string/staff_detail_status_icon_desc"
            android:src="@drawable/ic_circle_check" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
