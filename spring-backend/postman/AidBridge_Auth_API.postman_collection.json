        "url": {
          "raw": "{{baseUrl}}/api/auth/verify-otp",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "verify-otp"]
        },
        "description": "Note: Replace OTP with actual OTP from email/Redis"
      }
    },
    {
      "name": "7. Resend OTP",
      "event": [
