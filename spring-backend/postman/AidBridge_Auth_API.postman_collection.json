      "name": "4. Register - Duplicate Email (Error)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Should return 409 Conflict', function() {",
              "    pm.expect(pm.response.code).to.eql(409);",
              "});",
              "pm.test('Error message about duplicate email', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.false;",
              "    pm.expect(jsonData.message).to.include('Email');",
