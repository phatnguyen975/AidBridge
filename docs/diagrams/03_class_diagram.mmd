classDiagram
    class BaseActivity {
        <<abstract>>
        +getLoadingView() ProgressBar
        +showLoading()
        +hideLoading()
        +showToast()
    }
    class BaseFragment {
        <<abstract>>
        +showToast()
        +showLoading()
        +hideLoading()
        +showError()
    }
    class BaseViewModel {
        <<abstract>>
        -loading: MutableLiveData~Boolean~
        +setLoading(boolean)
        +isLoading: LiveData~Boolean~
    }

    BaseActivity <|-- AuthActivity
    BaseActivity <|-- UserGuideActivity
    BaseActivity <|-- MainActivity
    BaseActivity <|-- SplashActivity
    BaseFragment <|-- GuestFragment
    BaseFragment <|-- LoginFragment
    BaseFragment <|-- RegisterFragment
    BaseFragment <|-- OtpFragment
    BaseFragment <|-- ForgotEmailFragment
    BaseFragment <|-- ForgotOtpFragment
    BaseFragment <|-- ForgotNewPasswordFragment
    BaseFragment <|-- HomeFragment
    Fragment <|-- MapFragment
    BaseViewModel <|-- LoginViewModel
    BaseViewModel <|-- RegisterViewModel
    BaseViewModel <|-- OtpViewModel

    class LoginViewModel {
        -LoginUseCase loginUseCase
        +login(email, password)
        +loginResult: LiveData~NetworkResultWrapper~User~~
    }
    class OtpViewModel {
        -VerifyOtpUseCase verifyOtpUseCase
        -SavedStateHandle savedStateHandle
        +verify(otp)
        +resendOtp()
        +countdown: LiveData~Integer~
        +resendEnabled: LiveData~Boolean~
        +verifyResult: LiveData
    }
    class RegisterViewModel {
        -RegisterUseCase registerUseCase
        +register(name, phone, email, password, role)
        +selectRole(UserRole)
        +selectedRole: LiveData~UserRole~
        +registerResult: LiveData~NetworkResultWrapper~String~~
    }

    LoginFragment --> LoginViewModel
    OtpFragment --> OtpViewModel
    RegisterFragment --> RegisterViewModel

    class AuthRepositoryImpl {
        -AuthApiService authApiService
        -TokenManager tokenManager
        +login(email, password) LiveData
        +register(RegisterRequest) LiveData
        +verifyOtp(email, otp) LiveData
        +resendOtp(email) LiveData
    }
    class TokenManager {
        -SharedPreferences prefs
        +saveTokens(access, refresh)
        +saveUserInfo(id, name, email, role)
        +getAccessToken() String
        +getUserRole() String
        +clearAll()
    }
    class NetworkResultWrapper~T~ {
        <<abstract>>
    }
    class Success~T~ {
        +data: T
    }
    class Error~T~ {
        +message: String
        +code: int
    }
    class Loading~T~ {
    }
    NetworkResultWrapper <|-- Success
    NetworkResultWrapper <|-- Error
    NetworkResultWrapper <|-- Loading

    LoginViewModel --> AuthRepositoryImpl
    OtpViewModel --> AuthRepositoryImpl
    RegisterViewModel --> AuthRepositoryImpl
    AuthRepositoryImpl --> TokenManager
    HomeFragment --> TokenManager
    SplashActivity --> TokenManager
